echo -e "  Or directly : ${CYAN}sudo ${PYTHON} ${SCRIPT_DIR}/airjail${NC}"
echo ""
echo -e "  Captive portal (separate terminal):"
echo -e "              ${CYAN}sudo airjail-portal${NC}        ${DIM}# serve on :80${NC}"
echo -e "              ${CYAN}sudo airjail-portal 8080${NC}   ${DIM}# serve on :8080${NC}"
echo ""
echo -e "  ${YELLOW}Deauth requires a second USB WiFi adapter in monitor mode:${NC}"
echo -e "  ${CYAN}sudo airmon-ng check kill${NC}"
echo -e "  ${CYAN}sudo airmon-ng start wlan1${NC}    ${DIM}# → wlan1mon${NC}"
echo ""
echo -e "  ${DIM}To uninstall: sudo ./install uninstall${NC}"
echo ""
