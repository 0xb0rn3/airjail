#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
#
#   █████╗ ██╗██████╗      ██╗ █████╗ ██╗██╗
#  ██╔══██╗██║██╔══██╗     ██║██╔══██╗██║██║
#  ███████║██║██████╔╝     ██║███████║██║██║
#  ██╔══██║██║██╔══██╗██   ██║██╔══██║██║██║
#  ██║  ██║██║██║  ██║╚█████╔╝██║  ██║██║███████╗
#  ╚═╝  ╚═╝╚═╝╚═╝  ╚═╝ ╚════╝ ╚═╝  ╚═╝╚═╝╚══════╝
#
#  WiFi Network Manager & Abuse Control — Universal Installer
#  dev: 0xb0rn3 | oxbv1
#  github: https://github.com/0xb0rn3/airjail
#  version: 1.2.0
#
#  Supported package managers:
#    pacman  → Arch, Manjaro, EndeavourOS, Garuda, ArcoLinux, SteamOS
#    apt     → Debian, Ubuntu, Kali, Parrot, Pop!_OS, Mint, MX, Raspbian
#    dnf     → Fedora, RHEL 8+, CentOS Stream, AlmaLinux, Rocky, Oracle
#    yum     → RHEL 7, CentOS 7 (legacy)
#    zypper  → openSUSE Leap/Tumbleweed, SLES
#    apk     → Alpine Linux
#    xbps    → Void Linux
#    emerge  → Gentoo
#    eopkg   → Solus
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Do NOT use set -e — optional package installs must be allowed to fail
#    gracefully without aborting the whole script.
set -u
set -o pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Logging helpers ───────────────────────────────────────────────────────────
ok()    { echo -e "  ${GREEN}✓${NC} $*"; }
info()  { echo -e "  ${CYAN}*${NC} $*"; }
warn()  { echo -e "  ${YELLOW}!${NC} $*"; }
err()   { echo -e "  ${RED}✗${NC} $*"; }
step()  { echo -e "\n${BOLD}${CYAN}──────────────────────────────────────────${NC}"; \
          echo -e "  ${BOLD}$*${NC}"; \
          echo -e "${BOLD}${CYAN}──────────────────────────────────────────${NC}"; }
fail()  { err "$*"; exit 1; }

# ── Banner ────────────────────────────────────────────────────────────────────
print_banner() {
cat << 'BANNER'

  █████╗ ██╗██████╗      ██╗ █████╗ ██╗██╗
 ██╔══██╗██║██╔══██╗     ██║██╔══██╗██║██║
 ███████║██║██████╔╝     ██║███████║██║██║
 ██╔══██║██║██╔══██╗██   ██║██╔══██║██║██║
 ██║  ██║██║██║  ██║╚█████╔╝██║  ██║██║███████╗
 ╚═╝  ╚═╝╚═╝╚═╝  ╚═╝ ╚════╝ ╚═╝  ╚═╝╚═╝╚══════╝

  WiFi Network Manager & Abuse Control
  dev: 0xb0rn3 | oxbv1
  https://github.com/0xb0rn3/airjail

BANNER
}

# ── Root check ────────────────────────────────────────────────────────────────
[[ "${EUID:-$(id -u)}" -ne 0 ]] && fail "airjail installer must run as root → sudo ./install"

print_banner

# ── Script location (resolve symlinks) ───────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# ── Detect OS / distro ────────────────────────────────────────────────────────
DISTRO_ID=""
DISTRO_NAME=""
DISTRO_LIKE=""

if [[ -f /etc/os-release ]]; then
    # Use parameter expansion instead of grep -P (not available on Alpine)
    while IFS='=' read -r key val; do
        val="${val%\"}"   # strip trailing quote
        val="${val#\"}"   # strip leading quote
        case "$key" in
            ID)         DISTRO_ID="$val"   ;;
            NAME)       DISTRO_NAME="$val" ;;
            ID_LIKE)    DISTRO_LIKE="$val" ;;
        esac
    done < /etc/os-release
elif [[ -f /etc/lsb-release ]]; then
    DISTRO_NAME="$(grep DISTRIB_DESCRIPTION /etc/lsb-release | cut -d= -f2 | tr -d '"')"
elif command -v lsb_release &>/dev/null; then
    DISTRO_NAME="$(lsb_release -d -s 2>/dev/null || true)"
fi

DISTRO_NAME="${DISTRO_NAME:-Unknown}"
info "Distro  : ${BOLD}${DISTRO_NAME}${NC}"

# ── Detect package manager ────────────────────────────────────────────────────
#    Order matters — check most specific first to avoid false positives
#    (e.g. dnf/yum coexist on some RHEL systems, prefer dnf)
detect_pm() {
    if   command -v pacman      &>/dev/null; then echo "pacman"
    elif command -v apt-get     &>/dev/null; then echo "apt"
    elif command -v dnf         &>/dev/null; then echo "dnf"
    elif command -v yum         &>/dev/null; then echo "yum"
    elif command -v zypper      &>/dev/null; then echo "zypper"
    elif command -v apk         &>/dev/null; then echo "apk"
    elif command -v xbps-install &>/dev/null; then echo "xbps"
    elif command -v emerge      &>/dev/null; then echo "emerge"
    elif command -v eopkg       &>/dev/null; then echo "eopkg"
    else echo "unknown"
    fi
}

PM="$(detect_pm)"
info "PM      : ${BOLD}${PM}${NC}"

# ── Detect Python 3 binary ───────────────────────────────────────────────────
PYTHON=""
for _py in python3 python3.12 python3.11 python3.10 python3.9 python3.8 python; do
    if command -v "$_py" &>/dev/null; then
        _ver="$("$_py" -c 'import sys; print(sys.version_info[:2])' 2>/dev/null || true)"
        # Require >= (3, 8)
        if "$_py" -c 'import sys; sys.exit(0 if sys.version_info >= (3,8) else 1)' 2>/dev/null; then
            PYTHON="$_py"
            break
        fi
    fi
done

# ── Parse mode flag ───────────────────────────────────────────────────────────
MODE="${1:-install}"   # install | uninstall

# ══════════════════════════════════════════════════════════════════════════════
#  UNINSTALL
# ══════════════════════════════════════════════════════════════════════════════
if [[ "$MODE" == "uninstall" ]]; then
    step "Uninstalling airjail"
    rm -f /usr/local/bin/airjail           && ok "Removed /usr/local/bin/airjail"
    rm -f /usr/local/bin/airjail-portal    && ok "Removed /usr/local/bin/airjail-portal"
    rm -rf /var/lib/airjail                && ok "Removed /var/lib/airjail"
    # Flush any lingering iptables rules
    iptables -t nat -F PREROUTING 2>/dev/null && ok "Flushed NAT PREROUTING"
    iptables -F FORWARD            2>/dev/null && ok "Flushed FORWARD chain"
    echo ""
    ok "airjail uninstalled."
    exit 0
fi

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 1 — SYSTEM PACKAGE INSTALL
# ══════════════════════════════════════════════════════════════════════════════

# Package name map per PM.
# Format: associative array key = PM, value = space-separated package list.
# aircrack-ng is in most repos but may need enabling (e.g. RPM Fusion on Fedora).

declare -A SYS_PKGS
SYS_PKGS["pacman"]="python python-pip nmap net-tools aircrack-ng iptables iw wireless_tools libpcap"
SYS_PKGS["apt"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-dev"
SYS_PKGS["dnf"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-devel"
SYS_PKGS["yum"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-devel"
SYS_PKGS["zypper"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-devel"
SYS_PKGS["apk"]="python3 py3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-dev tcpdump"
SYS_PKGS["xbps"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless_tools libpcap-devel"
SYS_PKGS["emerge"]="net-analyzer/nmap sys-apps/net-tools net-wireless/aircrack-ng net-firewall/iptables net-wireless/iw net-wireless/wireless-tools net-libs/libpcap"
SYS_PKGS["eopkg"]="python3 python3-pip nmap net-tools aircrack-ng iptables iw wireless-tools libpcap-devel"

# ── Optional: enable extra repos that provide aircrack-ng ────────────────────
enable_extra_repos() {
    case "$PM" in
        dnf)
            # RPM Fusion free — provides aircrack-ng on Fedora/RHEL
            if ! rpm -q rpmfusion-free-release &>/dev/null; then
                info "Enabling RPM Fusion (free) for aircrack-ng..."
                local _fedver
                _fedver="$(rpm -E %fedora 2>/dev/null || echo 'unknown')"
                if [[ "$_fedver" != "unknown" ]]; then
                    dnf install -y -q \
                        "https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-${_fedver}.noarch.rpm" \
                        2>/dev/null && ok "RPM Fusion enabled" || warn "RPM Fusion install failed — aircrack-ng may be unavailable"
                fi
            fi
            ;;
        apk)
            # Alpine community repo is needed for aircrack-ng
            if ! grep -q "community" /etc/apk/repositories 2>/dev/null; then
                info "Enabling Alpine community repository..."
                local _ver
                _ver="$(cat /etc/alpine-release 2>/dev/null | cut -d. -f1-2 || echo 'edge')"
                echo "https://dl-cdn.alpinelinux.org/alpine/v${_ver}/community" \
                    >> /etc/apk/repositories
                apk update -q 2>/dev/null && ok "Alpine community repo enabled" \
                                          || warn "Could not update apk repos"
            fi
            ;;
        zypper)
            # Packman repo provides aircrack-ng on openSUSE
            if ! zypper lr | grep -qi packman 2>/dev/null; then
                info "Adding Packman repo for aircrack-ng..."
                local _osver
                _osver="$(grep VERSION_ID /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo '')"
                if [[ -n "$_osver" ]]; then
                    zypper addrepo -f \
                        "https://ftp.gwdg.de/pub/linux/misc/packman/suse/openSUSE_Leap_${_osver}/" \
                        packman 2>/dev/null && ok "Packman repo added" \
                                           || warn "Could not add Packman repo — aircrack-ng may be unavailable"
                fi
            fi
            ;;
    esac
}

# ── Run the right package manager ────────────────────────────────────────────
install_sys_pkgs() {
    step "Installing system packages"

    # Enable optional repos first (best-effort, non-fatal)
    enable_extra_repos

    # Pull package list for this PM
    local pkgs="${SYS_PKGS[$PM]:-}"

    if [[ -z "$pkgs" ]]; then
        warn "No package list defined for PM '${PM}'. Skipping system package install."
        warn "Install manually: python3 nmap aircrack-ng iptables iw net-tools libpcap"
        return 0
    fi

    local install_ok=0

    case "$PM" in
        pacman)
            info "Syncing pacman database..."
            pacman -Sy --noconfirm --quiet 2>/dev/null || true
            info "Installing packages..."
            # shellcheck disable=SC2086
            pacman -S --noconfirm --needed --quiet $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        apt)
            info "Running apt update..."
            DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true
            info "Installing packages..."
            DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
                --no-install-recommends $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        dnf)
            info "Installing packages (dnf)..."
            # shellcheck disable=SC2086
            dnf install -y -q $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        yum)
            info "Installing packages (yum)..."
            # shellcheck disable=SC2086
            yum install -y -q $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        zypper)
            info "Refreshing zypper repos..."
            zypper --non-interactive refresh 2>/dev/null || true
            info "Installing packages..."
            # shellcheck disable=SC2086
            zypper --non-interactive install --auto-agree-with-licenses \
                -l $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        apk)
            info "Updating apk index..."
            apk update -q 2>/dev/null || true
            info "Installing packages..."
            # shellcheck disable=SC2086
            apk add --no-cache -q $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        xbps)
            info "Syncing xbps repos..."
            xbps-install -Sy 2>/dev/null || true
            info "Installing packages..."
            # shellcheck disable=SC2086
            xbps-install -y $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        emerge)
            info "Running emerge sync..."
            emerge --sync --quiet 2>/dev/null || true
            info "Installing packages (emerge — this may take a while)..."
            # shellcheck disable=SC2086
            emerge --ask=n --quiet $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        eopkg)
            info "Updating eopkg repos..."
            eopkg update-repo 2>/dev/null || true
            info "Installing packages..."
            # shellcheck disable=SC2086
            eopkg install -y $pkgs 2>/dev/null \
                && install_ok=1 \
                || warn "Some packages failed — continuing"
            ;;

        *)
            warn "Unrecognised package manager: '${PM}'"
            warn "Please install the following manually, then re-run this script:"
            echo ""
            echo "    python3  nmap  aircrack-ng  iptables  iw  net-tools  libpcap"
            echo ""
            ;;
    esac

    [[ "$install_ok" -eq 1 ]] && ok "System packages installed" || true
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 2 — PYTHON VERSION VERIFICATION
# ══════════════════════════════════════════════════════════════════════════════

verify_python() {
    step "Verifying Python 3"

    # Re-detect after system package install (may have just been installed)
    if [[ -z "$PYTHON" ]]; then
        for _py in python3 python3.12 python3.11 python3.10 python3.9 python3.8 python; do
            if command -v "$_py" &>/dev/null; then
                if "$_py" -c 'import sys; sys.exit(0 if sys.version_info >= (3,8) else 1)' 2>/dev/null; then
                    PYTHON="$_py"
                    break
                fi
            fi
        done
    fi

    if [[ -z "$PYTHON" ]]; then
        fail "Python 3.8+ not found after install attempt. " \
             "Install it manually with your package manager, then re-run this script."
    fi

    local pyver
    pyver="$("$PYTHON" -c 'import sys; print(".".join(map(str,sys.version_info[:3])))')"
    ok "Python found  : $PYTHON ($pyver)"
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 3 — PIP BOOTSTRAP & PYTHON PACKAGE INSTALL
# ══════════════════════════════════════════════════════════════════════════════

# ── Determine whether pip needs --break-system-packages ──────────────────────
#    This flag was introduced in pip 23.0 and is required on distros that mark
#    their system Python as externally-managed (PEP 668).
#    Detection: check for EXTERNALLY-MANAGED marker file (most reliable).
needs_break_system_packages() {
    local _lib_path
    _lib_path="$("$PYTHON" -c \
        'import sys,os; print(next((p for p in sys.path if "site-packages" in p), ""))'
        2>/dev/null || true)"

    # PEP 668 marker
    if [[ -n "$_lib_path" ]]; then
        local _marker
        _marker="$(dirname "$_lib_path")/EXTERNALLY-MANAGED"
        [[ -f "$_marker" ]] && return 0
    fi

    # Also check pip version >= 23 (the flag exists regardless of marker on
    # some setups like recent Debian/Ubuntu)
    local _pip_ver
    _pip_ver="$("$PYTHON" -m pip --version 2>/dev/null | awk '{print $2}' | cut -d. -f1)"
    [[ "${_pip_ver:-0}" -ge 23 ]] && return 0

    return 1
}

# ── Bootstrap pip if missing ──────────────────────────────────────────────────
bootstrap_pip() {
    if "$PYTHON" -m pip --version &>/dev/null 2>&1; then
        return 0   # pip already available
    fi

    warn "pip not found — attempting to bootstrap..."

    # 1. Try ensurepip (stdlib module — available in most CPython builds)
    if "$PYTHON" -m ensurepip --upgrade 2>/dev/null; then
        ok "pip bootstrapped via ensurepip"
        return 0
    fi

    # 2. Try get-pip.py (requires curl or wget and network access)
    local _getpip="/tmp/airjail_get-pip.py"
    if command -v curl &>/dev/null; then
        curl -fsSL "https://bootstrap.pypa.io/get-pip.py" -o "$_getpip" 2>/dev/null
    elif command -v wget &>/dev/null; then
        wget -qO "$_getpip" "https://bootstrap.pypa.io/get-pip.py" 2>/dev/null
    fi

    if [[ -f "$_getpip" ]]; then
        "$PYTHON" "$_getpip" --quiet 2>/dev/null && ok "pip installed via get-pip.py" && return 0
    fi

    warn "Could not install pip. Python packages must be installed manually:"
    warn "  pip install rich scapy requests manuf"
    return 1
}

install_py_pkgs() {
    step "Installing Python packages"

    bootstrap_pip

    if ! "$PYTHON" -m pip --version &>/dev/null 2>&1; then
        warn "pip unavailable — skipping Python package install"
        return 0
    fi

    # Build flags list
    local pip_flags=("-q" "--upgrade")
    if needs_break_system_packages; then
        pip_flags+=("--break-system-packages")
        info "PEP 668 detected — using --break-system-packages"
    fi

    local pkg fail_list=()
    for pkg in rich scapy requests manuf; do
        if "$PYTHON" -m pip install "${pip_flags[@]}" "$pkg" 2>/dev/null; then
            ok "pip: $pkg"
        else
            warn "pip: $pkg — FAILED"
            fail_list+=("$pkg")
        fi
    done

    if [[ "${#fail_list[@]}" -gt 0 ]]; then
        warn "The following Python packages failed to install:"
        for pkg in "${fail_list[@]}"; do
            echo "    pip install $pkg ${pip_flags[*]}"
        done
        warn "Run the above commands manually to complete setup."
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 4 — SYSTEM CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

enable_ipfwd() {
    step "Enabling IP forwarding"

    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || warn "sysctl failed — try manually"

    # Persist across reboots in sysctl.conf
    local conf_file="/etc/sysctl.conf"
    # Some distros use /etc/sysctl.d/
    if [[ -d /etc/sysctl.d ]]; then
        conf_file="/etc/sysctl.d/99-airjail.conf"
    fi

    if grep -q "net.ipv4.ip_forward" "$conf_file" 2>/dev/null; then
        sed -i 's/^#*\s*net\.ipv4\.ip_forward.*/net.ipv4.ip_forward=1/' "$conf_file"
    else
        echo "net.ipv4.ip_forward=1" >> "$conf_file"
    fi

    ok "IP forwarding enabled (persisted to $conf_file)"
}

create_session_dir() {
    step "Creating session directory"
    mkdir -p /var/lib/airjail
    chmod 700 /var/lib/airjail
    ok "Session directory: /var/lib/airjail"
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 5 — LAUNCHER + PORTAL HELPER
# ══════════════════════════════════════════════════════════════════════════════

create_launcher() {
    step "Creating system launcher"

    # Main airjail launcher
    cat > /usr/local/bin/airjail << LAUNCHER
#!/usr/bin/env bash
# airjail system launcher — generated by installer
exec sudo "${PYTHON}" "${SCRIPT_DIR}/airjail" "\$@"
LAUNCHER
    chmod +x /usr/local/bin/airjail
    ok "Launcher created → /usr/local/bin/airjail"

    # Captive portal helper — starts a one-liner HTTP server on port 80
    # serving the bundled index.html from the airjail directory
    cat > /usr/local/bin/airjail-portal << PORTAL_LAUNCHER
#!/usr/bin/env bash
# airjail captive portal helper
# Usage: sudo airjail-portal [port]
#   Starts a simple HTTP server serving the airjail captive portal page.
#   Default port: 80

PORT="\${1:-80}"
PORTAL_DIR="${SCRIPT_DIR}"

if [[ ! -f "\${PORTAL_DIR}/index.html" ]]; then
    echo "[-] index.html not found in \${PORTAL_DIR}"
    echo "    Copy the airjail index.html there or run from the airjail directory."
    exit 1
fi

echo "[*] airjail captive portal starting on 0.0.0.0:\${PORT}"
echo "[*] Serving: \${PORTAL_DIR}/index.html"
echo "[*] Press Ctrl+C to stop"
echo ""
cd "\${PORTAL_DIR}" && exec ${PYTHON} -m http.server "\${PORT}" --bind 0.0.0.0
PORTAL_LAUNCHER
    chmod +x /usr/local/bin/airjail-portal
    ok "Portal helper created → /usr/local/bin/airjail-portal"
    ok "  Start portal with: sudo airjail-portal [port]"
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 6 — POST-INSTALL VERIFICATION
# ══════════════════════════════════════════════════════════════════════════════

verify_install() {
    step "Verifying installation"

    local all_ok=1

    # Required system tools
    local tools=("nmap" "iptables" "iw" "ip")
    local optional=("airmon-ng" "tcpdump")

    for tool in "${tools[@]}"; do
        if command -v "$tool" &>/dev/null; then
            ok "tool: $tool"
        else
            err "tool: $tool — NOT FOUND (required)"
            all_ok=0
        fi
    done

    for tool in "${optional[@]}"; do
        if command -v "$tool" &>/dev/null; then
            ok "tool: $tool"
        else
            warn "tool: $tool — not found (optional)"
        fi
    done

    # Required Python packages
    local py_pkgs=("rich" "scapy" "requests" "manuf")
    for pkg in "${py_pkgs[@]}"; do
        if "$PYTHON" -c "import ${pkg}" 2>/dev/null; then
            ok "python: $pkg"
        else
            err "python: $pkg — NOT IMPORTABLE"
            all_ok=0
        fi
    done

    # Launcher
    if [[ -x /usr/local/bin/airjail ]]; then
        ok "launcher: /usr/local/bin/airjail"
    else
        err "launcher: /usr/local/bin/airjail — NOT FOUND"
        all_ok=0
    fi

    # Session dir
    if [[ -d /var/lib/airjail ]]; then
        ok "session dir: /var/lib/airjail"
    else
        warn "session dir: /var/lib/airjail — missing (non-fatal)"
    fi

    echo ""
    if [[ "$all_ok" -eq 1 ]]; then
        echo -e "${GREEN}${BOLD}  ✓ All checks passed.${NC}"
    else
        echo -e "${YELLOW}${BOLD}  ! Some checks failed — see above.${NC}"
        echo -e "${DIM}  airjail may still work but some features could be broken.${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 7 — MAIN FLOW
# ══════════════════════════════════════════════════════════════════════════════

install_sys_pkgs
verify_python
install_py_pkgs
enable_ipfwd
create_session_dir
create_launcher
verify_install

# ── Final message ─────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}${BOLD}  ┌──────────────────────────────────────────┐"
