def _fmt(b):
    if b < 1024:        return f"{b} B"
    if b < 1_048_576:   return f"{b/1024:.1f} KB"
    if b < 1_073_741_824: return f"{b/1_048_576:.1f} MB"
    return f"{b/1_073_741_824:.2f} GB"

def get_default_iface():
    try:
        out = subprocess.check_output(["ip","route"], text=True)
        for line in out.splitlines():
            if line.startswith("default"):
                return line.split()[line.split().index("dev")+1]
    except Exception:
        pass
    return "wlan0"

def get_gateway():
    try:
        out = subprocess.check_output(["ip","route"], text=True)
        for line in out.splitlines():
            if line.startswith("default"):
                gw = line.split()[2]
                ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(pdst=gw),
                             iface=IFACE, timeout=2, verbose=False)
                if ans:
                    return gw, ans[0][1].hwsrc
                return gw, None
    except Exception:
        pass
    return None, None

def get_local_subnet():
    try:
        out = subprocess.check_output(
            ["ip","-o","-f","inet","addr","show", IFACE], text=True)
        m = re.search(r"(\d+\.\d+\.\d+\.\d+/\d+)", out)
        if m: return m.group(1)
    except Exception:
        pass
    return "192.168.1.0/24"

def pick_interface():
    """Show a numbered interface selection menu and return chosen iface name."""
    clear(); banner()
    console.print("[bold cyan]в”Ђв”Ђ Select Network Interface в”Ђв”Ђ[/]\n")

    # gather all interfaces with metadata
    raw_ifaces = []
    try:
        out = subprocess.check_output(["ip", "-o", "link", "show"], text=True)
        for line in out.splitlines():
            parts  = line.split()
            idx    = parts[0].rstrip(":")
            name   = parts[1].rstrip(":")
            # skip loopback
            if name == "lo":
                continue
            # get IP if any
            try:
                ip_out = subprocess.check_output(
                    ["ip", "-o", "-f", "inet", "addr", "show", name], text=True)
                m = re.search(r"(\d+\.\d+\.\d+\.\d+/\d+)", ip_out)
                ip_addr = m.group(1) if m else "no IP"
            except Exception:
                ip_addr = "no IP"
            # get state
            state_m = re.search(r"state (\S+)", line)
            state   = state_m.group(1) if state_m else "UNKNOWN"
            # get MAC
            mac_m   = re.search(r"link/\S+ ([0-9a-f:]{17})", line)
            mac     = mac_m.group(1) if mac_m else "вЂ”"
            # is wireless?
            is_wifi = os.path.exists(f"/sys/class/net/{name}/wireless")
            if is_wifi and ADAPTER_CHIPSET and ADAPTER_USB_ID:
                kind = f"[cyan]WiFi[/] [dim yellow]{ADAPTER_CHIPSET}[/]"
            elif is_wifi:
                kind = "[cyan]WiFi[/]"
            else:
                kind = "[dim]LAN [/]"

            raw_ifaces.append({
                "name": name, "ip": ip_addr, "mac": mac,
                "state": state, "kind": kind
            })
    except Exception:
        # fallback: scapy list
        names = get_if_list() if SCAPY_OK else []
        raw_ifaces = [{"name": n, "ip": "вЂ”", "mac": "вЂ”",
                       "state": "?", "kind": "[dim]вЂ”[/]"} for n in names if n != "lo"]

    if not raw_ifaces:
        console.print("[yellow]No interfaces found. Enter manually.[/]")
        return Prompt.ask("[cyan]Interface name[/]", default="wlan0")

    table = Table(box=box.ROUNDED, border_style="cyan", show_lines=True)
    table.add_column("#",       style="bold yellow", width=4, justify="right")
    table.add_column("Name",    style="bold cyan",   width=12)
    table.add_column("Type",    width=8)
    table.add_column("IP / Subnet",   style="green",   width=20)
    table.add_column("MAC",     style="yellow",  width=20)
    table.add_column("State",   width=10)

    default_name = get_default_iface()
    for i, iface in enumerate(raw_ifaces, 1):
        state_color = "[green]" if "UP" in iface["state"] else "[red]"
        marker      = " [bold yellow]в†ђ default[/]" if iface["name"] == default_name else ""
        table.add_row(
            str(i),
            f"{iface['name']}{marker}",
            iface["kind"],
            iface["ip"],
            iface["mac"],
            f"{state_color}{iface['state']}[/]"
        )

    console.print(table)
    console.print(f"\n[dim]Default auto-detected: [cyan]{default_name}[/][/]\n")

    while True:
        choice = Prompt.ask(
            "[bold cyan]Select interface #[/] [dim](or type name directly)[/]"
        ).strip()

