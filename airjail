def _bw_thread(stop_ev):
    """Parse iptables FORWARD counters correctly using --zero-friendly column layout."""
    while not stop_ev.is_set():
        try:
            out = subprocess.check_output(
                ["iptables", "-nvxL", "FORWARD", "--line-numbers"],
                text=True, stderr=subprocess.DEVNULL)
            for line in out.splitlines():
                # Line format: num pkts bytes target prot opt in out src dst [opts]
                parts = line.split()
                if len(parts) < 10:
                    continue
                try:
                    # col 2 = bytes, col 8 = src, col 9 = dst
                    byte_count = int(parts[2])
                    src_ip = parts[8]
                    dst_ip = parts[9]
                    if re.match(r"\d+\.\d+\.\d+\.\d+$", src_ip) and src_ip != "0.0.0.0/0":
                        BW_STATS[src_ip]["tx"] = byte_count
                    if re.match(r"\d+\.\d+\.\d+\.\d+$", dst_ip) and dst_ip != "0.0.0.0/0":
                        BW_STATS[dst_ip]["rx"] = byte_count
                except (ValueError, IndexError):
                    pass

            # Auto-jail threshold check
            if BW_THRESHOLD_BYTES > 0 and REDIRECT_IP:
                for ip, stats in BW_STATS.items():
                    total = stats["rx"] + stats["tx"]
                    if total >= BW_THRESHOLD_BYTES:
                        # Find MAC for this IP
                        mac = _arp_table.get(ip, "unknown")
                        if mac.lower() not in JAILED:
                            _redirect_on(ip, REDIRECT_IP, REDIRECT_PORT)
                            JAILED[mac.lower()] = {
                                "ip": ip,
                                "reason": f"BW limit exceeded ({_fmt(total)})",
                                "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                            }
                            console.log(
                                f"[red][AUTO-JAIL] {ip} ({mac}) вЂ” BW {_fmt(total)} exceeded threshold[/]")
        except Exception:
            pass
        time.sleep(2)


def _setup_bw_rules(devices):
    subprocess.run(["iptables", "-F", "FORWARD"],
                   check=False, stderr=subprocess.DEVNULL)
    for d in devices:
        subprocess.run(["iptables", "-A", "FORWARD", "-s", d["ip"]],
                       check=False, stderr=subprocess.DEVNULL)
        subprocess.run(["iptables", "-A", "FORWARD", "-d", d["ip"]],
                       check=False, stderr=subprocess.DEVNULL)


