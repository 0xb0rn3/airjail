    table.add_column(style="dim",     width=50)

    for key, name, desc, color in rows:
        table.add_row(
            f"[{color}][{key}][/{color}]",
            f"[{color}]{name}[/{color}]",
            desc
        )

    console.print(table)

    # Status bar — includes adapter chipset, LED state, monitor ifaces
    adapter_tag = ""
    if ADAPTER_CHIPSET:
        led_tag = " [green]LED[/]" if (ADAPTER_LED and LED._enabled) else ""
        adapter_tag = f"  adapter:[magenta]{ADAPTER_CHIPSET}[/]{led_tag}"
    mon_tag = ""
    if _MON_IFACES:
        mon_names = ",".join(_MON_IFACES.keys())
        mon_tag = f"  mon:[red]{mon_names}[/]"
    console.print(
        f"  iface:[cyan]{IFACE}[/]  gw:[cyan]{GATEWAY_IP or '?'}[/]  "
        f"dns:{'[green]on[/]' if 'dns' in _stop_events else '[red]off[/]'}  "
        f"jailed:[{'red' if JAILED else 'dim'}]{len(JAILED)}[/]  "
        f"portal:[cyan]{REDIRECT_IP or 'not set'}[/]{adapter_tag}{mon_tag}"
    )
    return Prompt.ask("\n[bold cyan]airjail >[/]").strip().upper()

def run():
    global IFACE, GATEWAY_IP, GATEWAY_MAC

    # ── USB adapter detection (populates globals + fires LED boot) ────────────
    clear(); banner()
    with console.status("[cyan]Scanning USB bus for wireless adapter..."):
        adapter = detect_usb_adapter(silent=True)
    if adapter:
        cs_badge  = f"[bold cyan]{adapter['chipset']}[/]"
        vnd_badge = f"[dim]{adapter['vendor']}[/]"
        led_badge = "[green]LED ✓[/]" if adapter["led"] else "[dim]no LED[/]"
        console.print(f"[green][✓] Adapter: {cs_badge}  {vnd_badge}  "
                      f"USB: [yellow]{adapter['usb_id']}[/]  {led_badge}[/]")
        LED.boot_sequence()
    else:
        console.print("[dim][·] No adapter in database — use [A] Adapter menu to detect/install.[/]")

    # ── first-run interface selection ─────────────────────────────────────────
    IFACE = pick_interface()
    clear(); banner()
    with console.status(f"[cyan]Auto-detecting gateway on {IFACE}..."):
        GATEWAY_IP, GATEWAY_MAC = get_gateway()
    if GATEWAY_IP:
        console.print(f"[green][✓] Gateway: [bold]{GATEWAY_IP}[/bold]  MAC: {GATEWAY_MAC}[/]")
    else:
        console.print(f"[yellow][!] Could not auto-detect gateway.[/]")
        GATEWAY_IP  = Prompt.ask("[cyan]Enter gateway IP[/]", default="192.168.1.1")
        GATEWAY_MAC = Prompt.ask("[cyan]Enter gateway MAC[/]", default="")
    if SCAPY_OK:
        start_dns_monitor()
        console.print(f"[green][✓] DNS monitor started on {IFACE}[/]")
    subprocess.run(["sysctl","-w","net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    console.print("[green][✓] IP forwarding enabled.[/]")
    time.sleep(1)
    # ─────────────────────────────────────────────────────────────────────────

    handlers = {
        "1": menu_scan,
        "2": menu_device_lookup,
        "3": menu_deauth,
        "4": menu_dns_spy,
        "5": menu_bandwidth,
        "6": menu_redirect,
        "7": menu_firewall,
        "8": menu_setup,
        "A": menu_adapter,
        "M": menu_monitor_mode,
    }
    while True:
        ch = main_menu()
        if ch == "Q":
            # stop all MITM sessions
            for ip in list(_mitm_sessions.keys()):
                _mitm_stop(ip)
            # stop all monitor mode sessions
            for mon, orig in list(_mon_ifaces.items()):
                _disable_monitor(mon)
            _stop_hop()
            LED.monitor_stop()
            LED.off()
            for ev in _stop_events.values(): ev.set()
            console.print("\n[bold cyan]airjail | 0xb0rn3 — goodbye.[/]\n")
            sys.exit(0)
        fn = handlers.get(ch)
        if fn:
            fn()

if __name__ == "__main__":
    run()
