def _run_nmap(ip: str):
    """nmap wrapper вЂ” 4 presets + custom. Results in Rich table."""
    console.print(f"\n[cyan]Port scanning [bold]{ip}[/bold]...[/]\n")
    presets = [
        ("-sV -T4 --open -p-",            "Full (65535 ports + version)"),
        ("-sV -T4 --open --top-ports 1000","Top 1000 + version"),
        ("-sV -sC -T4 --open -p-",         "Full + NSE scripts"),
        ("-sU -T4 --top-ports 100",         "Top 100 UDP"),
    ]
    for i, (flags, desc) in enumerate(presets, 1):
        console.print(f"  [bold yellow][{i}][/] {desc}")
    console.print(f"  [bold yellow][5][/] Custom flags")

    choice = Prompt.ask("[cyan]Preset[/]", default="2").strip()
    if choice.isdigit() and 1 <= int(choice) <= 4:
        flags = presets[int(choice)-1][0]
