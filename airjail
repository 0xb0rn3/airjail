    ).strip().upper()
    if thresh_str and thresh_str != "0":
        m = re.match(r"(\d+(?:\.\d+)?)\s*(MB|GB|KB|B)?", thresh_str)
        if m:
            val, unit = float(m.group(1)), (m.group(2) or "MB")
            mult = {"B": 1, "KB": 1024, "MB": 1_048_576, "GB": 1_073_741_824}
            BW_THRESHOLD_BYTES = int(val * mult.get(unit, 1_048_576))
            console.print(f"[green][вњ“] Auto-jail threshold: {_fmt(BW_THRESHOLD_BYTES)}[/]")
        else:
            console.print("[yellow]Invalid format вЂ” threshold disabled.[/]")
            BW_THRESHOLD_BYTES = 0
    else:
        BW_THRESHOLD_BYTES = 0

    stop_ev = threading.Event()
    _stop_events["bw"] = stop_ev
    threading.Thread(target=_bw_thread, args=(stop_ev,), daemon=True).start()

    start_ts = datetime.now()
    console.print("[dim]Press Ctrl+C to exit bandwidth monitor[/]\n")

    try:
