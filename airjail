def _pcap_ensure_dir():
    os.makedirs(PCAP_DIR, exist_ok=True)

def pcap_start(name: str = "", iface: str = "", bpf: str = "",
               target_ip: str = "") -> str:
    _pcap_ensure_dir()
    if not name:
        name = f"cap_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    if not iface:
        iface = IFACE or "any"
    path = os.path.join(PCAP_DIR, f"{name}.pcap")
    cmd = ["tcpdump", "-i", iface, "-w", path, "-U"]
    if bpf:
        cmd += bpf.split()
    elif target_ip:
        cmd += ["host", target_ip]
    stop_ev = threading.Event()
    def _run():
        try:
            proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL,
                                    stderr=subprocess.DEVNULL)
            while not stop_ev.is_set():
                stop_ev.wait(timeout=1)
            proc.terminate(); proc.wait(timeout=5)
        except Exception: pass
    t = threading.Thread(target=_run, daemon=True); t.start()
    _pcap_sessions[name] = {"stop_ev": stop_ev, "thread": t, "path": path,
                             "iface": iface, "bpf": bpf,
                             "started": datetime.now().isoformat()}
    forensic_event("pcap_start", {"name": name, "path": path, "iface": iface})
    return path

def pcap_stop(name: str) -> str | None:
    sess = _pcap_sessions.pop(name, None)
    if not sess: return None
    sess["stop_ev"].set()
    if sess["thread"].is_alive(): sess["thread"].join(timeout=5)
    forensic_event("pcap_stop", {"name": name, "path": sess["path"]})
    return sess["path"]

def pcap_list_files() -> list:
    _pcap_ensure_dir()
    files = []
    for f in sorted(glob.glob(os.path.join(PCAP_DIR, "*.pcap*"))):
        stat = os.stat(f)
        files.append({"path": f, "name": os.path.basename(f),
                       "size": stat.st_size,
                       "modified": datetime.fromtimestamp(stat.st_mtime).strftime("%Y-%m-%d %H:%M:%S")})
    return files

def pcap_analyze(path: str) -> dict:
    if not SCAPY_OK: return {"error": "scapy unavailable"}
    try: pkts = rdpcap(path, count=5000)
    except Exception as e: return {"error": str(e)}
    stats = {"total_packets": len(pkts), "protocols": defaultdict(int),
             "src_ips": defaultdict(int), "dst_ips": defaultdict(int),
             "ports": defaultdict(int)}
    for pkt in pkts:
        if pkt.haslayer(TCP):  stats["protocols"]["TCP"] += 1; stats["ports"][pkt[TCP].dport] += 1
        elif pkt.haslayer(UDP): stats["protocols"]["UDP"] += 1; stats["ports"][pkt[UDP].dport] += 1
        elif pkt.haslayer(ICMP): stats["protocols"]["ICMP"] += 1
        if pkt.haslayer(IP):
            stats["src_ips"][pkt[IP].src] += 1; stats["dst_ips"][pkt[IP].dst] += 1
        if pkt.haslayer(DNS): stats["protocols"]["DNS"] += 1
        if pkt.haslayer(ARP): stats["protocols"]["ARP"] += 1
    for k in ("protocols","src_ips","dst_ips","ports"):
        stats[k] = dict(sorted(dict(stats[k]).items(), key=lambda x: -x[1])[:20])
    return stats

