    tbl.add_column("State",   style="green")
    tbl.add_column("Service", style="cyan")
    tbl.add_column("Version", style="dim")

    for line in out.splitlines():
        m = re.match(r"(\d+/\w+)\s+(\w+)\s+(\S+)(?:\s+(.+))?", line)
        if m:
            tbl.add_row(m.group(1), m.group(2), m.group(3), m.group(4) or "")

    console.print(tbl)

def _mitm_stop(ip: str):
    """Stop an active ARP MITM session and restore ARP tables."""
    sess = _mitm_sessions.pop(ip, None)
    if not sess:
        return
    sess["stop_ev"].set()
    if sess.get("thread") and sess["thread"].is_alive():
        sess["thread"].join(timeout=3)
    # send gratuitous ARP restore to both sides
    if SCAPY_OK and GATEWAY_IP and GATEWAY_MAC:
        try:
            restore_t = ARP(op=2, pdst=ip, hwdst="ff:ff:ff:ff:ff:ff",
                            psrc=GATEWAY_IP, hwsrc=GATEWAY_MAC)
            restore_g = ARP(op=2, pdst=GATEWAY_IP, hwdst="ff:ff:ff:ff:ff:ff",
                            psrc=ip, hwsrc=sess.get("target_mac", "ff:ff:ff:ff:ff:ff"))
            send(restore_t, count=5, verbose=False, iface=IFACE)
            send(restore_g, count=5, verbose=False, iface=IFACE)
        except Exception:
            pass

