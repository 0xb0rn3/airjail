def _bw_thread(stop_ev):
    """Count bytes per client IP using iptables FORWARD chain."""
    while not stop_ev.is_set():
        try:
            out = subprocess.check_output(
                ["iptables", "-nvxL", "FORWARD"], text=True, stderr=subprocess.DEVNULL)
            for line in out.splitlines():
                parts = line.split()
                if len(parts) < 10: continue
                # source IP → TX bytes
                if re.match(r"\d+\.\d+\.\d+\.\d+", parts[8] if len(parts)>8 else ""):
                    BW_STATS[parts[8]]["tx"] = int(parts[1])
                # dest IP → RX bytes
                if re.match(r"\d+\.\d+\.\d+\.\d+", parts[9] if len(parts)>9 else ""):
                    BW_STATS[parts[9]]["rx"] = int(parts[1])
        except Exception:
            pass
        time.sleep(2)

def _setup_bw_rules(devices):
    subprocess.run(["iptables","-F","FORWARD"], check=False, stderr=subprocess.DEVNULL)
    for d in devices:
        subprocess.run(["iptables","-A","FORWARD","-s",d["ip"]],
                       check=False, stderr=subprocess.DEVNULL)
        subprocess.run(["iptables","-A","FORWARD","-d",d["ip"]],
                       check=False, stderr=subprocess.DEVNULL)

def menu_bandwidth():
    devices = scan_network()
    if not devices:
        console.print("[yellow]No devices found.[/]")
        input("\nEnter to continue..."); return

    _setup_bw_rules(devices)
    dev_map  = {d["ip"]: d["mac"] for d in devices}
    stop_ev  = threading.Event()
    _stop_events["bw"] = stop_ev
    threading.Thread(target=_bw_thread, args=(stop_ev,), daemon=True).start()

    start_ts = datetime.now()
    console.print("[dim]Press Ctrl+C to exit bandwidth monitor[/]\n")

    try:
        while True:
            elapsed = str(timedelta(seconds=int(
                (datetime.now()-start_ts).total_seconds())))

            table = Table(
                title=f"[bold cyan]Bandwidth Monitor[/] [dim]uptime {elapsed}[/]",
                box=box.ROUNDED, border_style="cyan", show_lines=True)
            table.add_column("IP",    style="green")
            table.add_column("MAC",   style="yellow")
            table.add_column("↓ RX",  style="cyan",    justify="right")
            table.add_column("↑ TX",  style="magenta", justify="right")
            table.add_column("Total", style="bold",    justify="right")
            table.add_column("Status",style="bold")

            for ip, mac in dev_map.items():
                bw     = BW_STATS[ip]
                total  = bw["rx"] + bw["tx"]
                jailed = mac.lower() in JAILED
                status = "[red]⛔ JAILED[/]" if jailed else "[green]✓[/]"
                table.add_row(ip, mac,
                              _fmt(bw["rx"]), _fmt(bw["tx"]),
                              _fmt(total), status)

            console.clear()
            banner()
            console.print(table)
            console.print("\n[dim]Ctrl+C to exit[/]")
            time.sleep(3)

    except KeyboardInterrupt:
        stop_ev.set()
        console.print("\n[yellow][*] Bandwidth monitor stopped.[/]")
        input("\nEnter to continue...")

