def _fmt(b):
    if b < 1024:            return f"{b} B"
    if b < 1_048_576:       return f"{b/1024:.1f} KB"
    if b < 1_073_741_824:   return f"{b/1_048_576:.1f} MB"
    return f"{b/1_073_741_824:.2f} GB"


def get_default_iface():
    try:
        out = subprocess.check_output(["ip", "route"], text=True)
        for line in out.splitlines():
            if line.startswith("default"):
                return line.split()[line.split().index("dev") + 1]
    except Exception:
        pass
    return "wlan0"


def get_gateway():
    try:
        out = subprocess.check_output(["ip", "route"], text=True)
        for line in out.splitlines():
            if line.startswith("default"):
                gw  = line.split()[2]
                ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff") / ARP(pdst=gw),
                             iface=IFACE, timeout=2, verbose=False)
                if ans:
                    return gw, ans[0][1].hwsrc
                return gw, None
    except Exception:
        pass
    return None, None


def get_local_subnet():
    try:
        out = subprocess.check_output(
            ["ip", "-o", "-f", "inet", "addr", "show", IFACE], text=True)
        m = re.search(r"(\d+\.\d+\.\d+\.\d+/\d+)", out)
        if m: return m.group(1)
    except Exception:
        pass
    return "192.168.1.0/24"


