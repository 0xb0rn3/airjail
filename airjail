def detect_usb_adapter(silent: bool = False) -> dict | None:
    """
    Scan `lsusb` output against ADAPTER_DB.
    Populates the ADAPTER_* globals and wires up LED if the adapter supports it.
    Returns a dict with adapter info, or None if nothing matched.
    """
    global ADAPTER_USB_ID, ADAPTER_CHIPSET, ADAPTER_VENDOR
    global ADAPTER_DRIVER, ADAPTER_INSTALL, ADAPTER_LED

    try:
        usb_out = subprocess.check_output(["lsusb"], text=True,
                                          stderr=subprocess.DEVNULL)
    except Exception:
        if not silent:
            pass  # lsusb not available вЂ” skip silently
        return None

    for usb_id, info in ADAPTER_DB.items():
        if usb_id.lower() in usb_out.lower():
            chipset, vendor, driver, method, led = info
            ADAPTER_USB_ID  = usb_id
            ADAPTER_CHIPSET = chipset
            ADAPTER_VENDOR  = vendor
            ADAPTER_DRIVER  = driver
            ADAPTER_INSTALL = method
            ADAPTER_LED     = led
            # Re-init LED engine now that we know LED capability
            if led:
                LED.refresh()
            return {
                "usb_id": usb_id, "chipset": chipset, "vendor": vendor,
                "driver": driver, "method": method, "led": led,
                "lsusb_line": next(
                    (l for l in usb_out.splitlines() if usb_id.lower() in l.lower()),
                    "вЂ”"
                ),
            }

    # Fuzzy fallback: detect any known vendor prefix
    for prefix, (chipset, vendor) in {
        "0e8d:": ("MT76xx", "MediaTek"),
        "0bda:": ("Realtek", "Realtek"),
        "148f:": ("Ralink/MT", "Ralink"),
        "0cf3:": ("AR9xxx", "Atheros"),
    }.items():
        if prefix in usb_out.lower():
            if not silent:
                pass
            ADAPTER_CHIPSET = chipset
            ADAPTER_VENDOR  = vendor
            ADAPTER_LED     = False
            return {
                "usb_id": f"{prefix}????", "chipset": chipset,
                "vendor": vendor, "driver": "unknown",
                "method": "unknown", "led": False,
                "lsusb_line": "unknown вЂ” USB ID not in database",
            }

    return None


