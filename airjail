def scan_network(subnet=None, silent=False):
    if not SCAPY_OK:
        console.print("[red]Scapy unavailable[/]"); return []
    if subnet is None:
        subnet = get_local_subnet()
    if not silent:
        console.print(f"\n[cyan][*] Scanning {subnet} on [bold]{IFACE}[/bold]...[/]")
    try:
        ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff")/ARP(pdst=subnet),
                     iface=IFACE, timeout=3, verbose=False)
    except Exception as e:
        console.print(f"[red]Scan error: {e}[/]"); return []
    return [{"ip": p[ARP].psrc, "mac": p[ARP].hwsrc} for _, p in ans]

def menu_scan():
    devices = scan_network()
    if not devices:
        console.print("[yellow]No devices found.[/]")
        input("\nEnter to continue..."); return

    table = Table(title="[bold cyan]Network Devices[/]",
                  box=box.ROUNDED, border_style="cyan", show_lines=True)
    table.add_column("#",          style="dim",     width=4)
    table.add_column("IP",         style="green")
    table.add_column("MAC",        style="yellow")
    table.add_column("Vendor",     style="magenta")
    table.add_column("Hostname",   style="blue")
    table.add_column("BW Used",    style="cyan",  justify="right")
    table.add_column("Status",     style="bold")

    for i, d in enumerate(devices, 1):
        vendor   = mac_vendor(d["mac"])
        hostname = hostname_lookup(d["ip"])
        jailed   = d["mac"].lower() in JAILED
        bw       = BW_STATS[d["ip"]]
        total    = _fmt(bw["rx"] + bw["tx"])
        status   = "[red]⛔ JAILED[/]" if jailed else "[green]✓ Online[/]"
        table.add_row(str(i), d["ip"], d["mac"], vendor, hostname, total, status)

    console.print(table)
    console.print(f"\n[dim]Total: {len(devices)} device(s)[/]")
    input("\nEnter to continue...")

