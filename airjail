def _dns_cb(pkt):
    if pkt.haslayer(DNS) and pkt.haslayer(DNSQR) and pkt[DNS].qr == 0:
        try:
            src  = pkt.src.lower() if hasattr(pkt, "src") else "unknown"
            dom  = pkt[DNSQR].qname.decode(errors="ignore").rstrip(".")
            if dom and dom not in DNS_LOG[src]:
                DNS_LOG[src].append(dom)
                if len(DNS_LOG[src]) > 300:
                    DNS_LOG[src] = DNS_LOG[src][-300:]
        except Exception:
            pass

def start_dns_monitor():
    if "dns" in _stop_events: return
    LED.dns_start()
    ev = threading.Event()
    _stop_events["dns"] = ev
    threading.Thread(
        target=lambda: sniff(iface=IFACE, filter="udp port 53",
                              prn=_dns_cb, store=False,
                              stop_filter=lambda _: ev.is_set()),
        daemon=True
    ).start()

