                f"[green][вњ“] Continuous deauth loop started for {target_mac}. "
                f"Stop via Jail menu в†’ Release.[/]")
    else:
        with console.status(f"[red]Sending {count} deauth frames to {target_mac}..."):
            try:
                deauth_target(target_mac, ap_mac, mon_iface, count)
                JAILED[target_mac.lower()] = {
                    "ip": "вЂ”", "reason": "Deauth (manual)",
                    "time": datetime.now().strftime("%H:%M:%S")
                }
                console.print(f"[green][вњ“] Done. {target_mac} deauthed and marked jailed.[/]")
            except Exception as e:
