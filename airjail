                    pct    = min(100, int(total * 100 / BW_THRESHOLD_BYTES))
                    bar    = f" [{'red' if pct > 80 else 'yellow'}]{pct}%[/]"
                else:
                    bar = ""
                status = "[red]в›” JAILED[/]" if jailed else "[green]вњ“[/]"
                table.add_row(ip, mac, _fmt(bw["rx"]), _fmt(bw["tx"]),
