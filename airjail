                m       = re.search(r"(\d+\.\d+\.\d+\.\d+/\d+)", ip_out)
                ip_addr = m.group(1) if m else "no IP"
            except Exception:
                ip_addr = "no IP"
            state_m = re.search(r"state (\S+)", line)
            state   = state_m.group(1) if state_m else "UNKNOWN"
            mac_m   = re.search(r"link/\S+ ([0-9a-f:]{17})", line)
            mac     = mac_m.group(1) if mac_m else "вЂ”"
            is_wifi = os.path.exists(f"/sys/class/net/{name}/wireless")
            kind    = "[cyan]WiFi[/]" if is_wifi else "[dim]LAN [/]"
            raw_ifaces.append({"name": name, "ip": ip_addr, "mac": mac,
                               "state": state, "kind": kind})
    except Exception:
        names      = get_if_list() if SCAPY_OK else []
        raw_ifaces = [{"name": n, "ip": "вЂ”", "mac": "вЂ”", "state": "?", "kind": "[dim]вЂ”[/]"}
                      for n in names if n != "lo"]

    if not raw_ifaces:
        console.print("[yellow]No interfaces found. Enter manually.[/]")
        return Prompt.ask("[cyan]Interface name[/]", default="wlan0")

    table = Table(box=box.ROUNDED, border_style="cyan", show_lines=True)
    table.add_column("#",          style="bold yellow", width=4,  justify="right")
    table.add_column("Name",       style="bold cyan",   width=12)
    table.add_column("Type",       width=8)
    table.add_column("IP / Subnet",style="green",       width=20)
    table.add_column("MAC",        style="yellow",      width=20)
    table.add_column("State",      width=10)

    default_name = get_default_iface()
    for i, iface in enumerate(raw_ifaces, 1):
        state_color = "[green]" if "UP" in iface["state"] else "[red]"
        marker      = " [bold yellow]в†ђ default[/]" if iface["name"] == default_name else ""
        table.add_row(str(i), f"{iface['name']}{marker}", iface["kind"],
                      iface["ip"], iface["mac"],
                      f"{state_color}{iface['state']}[/]")

    console.print(table)
    console.print(f"\n[dim]Default auto-detected: [cyan]{default_name}[/][/]\n")

    while True:
        choice = Prompt.ask(
            "[bold cyan]Select interface #[/] [dim](or type name directly)[/]"
        ).strip()
        if choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(raw_ifaces):
                selected = raw_ifaces[idx - 1]["name"]
                console.print(f"\n[green][вњ“] Interface set в†’ [bold]{selected}[/bold][/]")
                time.sleep(0.6)
                return selected
            console.print(f"[red]Enter a number between 1 and {len(raw_ifaces)}[/]")
        elif choice:
            console.print(f"\n[green][вњ“] Interface set в†’ [bold]{choice}[/bold][/]")
            time.sleep(0.6)
            return choice


def mac_vendor(mac: str) -> str:
    """Cached MAC vendor lookup вЂ” manuf first, API fallback."""
    mac_lower = mac.lower()
    if mac_lower in _vendor_cache:
        return _vendor_cache[mac_lower]

    vendor = "Unknown"
    if MANUF_OK:
        try:
            p = manuf.MacParser()
            v = p.get_manuf(mac)
            if v:
                vendor = v
        except Exception:
            pass

    if vendor == "Unknown":
        try:
            r = requests.get(f"https://api.macvendors.com/{mac}", timeout=3)
            if r.status_code == 200:
                vendor = r.text.strip()
        except Exception:
            pass

    _vendor_cache[mac_lower] = vendor
    return vendor


def hostname_lookup(ip: str) -> str:
    try:
        return socket.gethostbyaddr(ip)[0]
    except Exception:
        return "вЂ”"


