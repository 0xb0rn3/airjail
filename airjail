def main_menu():
    clear(); banner()

    rows = [
        ("1", "Network Scan",      "Discover LAN devices — IP, MAC, vendor, hostname",  "green"),
        ("2", "Device Lookup",     "Deep info + DNS history for any device",             "cyan"),
        ("3", "Deauth",            "Kick device off WiFi (needs monitor adapter)",       "red"),
        ("4", "DNS Spy",           "Passively see what sites each user visits",          "yellow"),
        ("5", "Bandwidth Monitor", "Real-time per-device RX/TX usage",                  "magenta"),
        ("6", "Jail / Redirect",   "Captive portal redirect & user jail manager",       "bold red"),
        ("7", "Firewall Status",   "Live iptables rule viewer",                         "dim cyan"),
        ("8", "Setup",             "Configure interface, gateway & portal",              "blue"),
        ("Q", "Quit",              "",                                                   "dim"),
    ]

    table = Table(box=box.ROUNDED, border_style="cyan",
                  show_header=False, padding=(0,2))
    table.add_column(justify="right", style="bold yellow", width=4)
    table.add_column(style="bold",    width=22)
    table.add_column(style="dim",     width=50)

    for key, name, desc, color in rows:
        table.add_row(
            f"[{color}][{key}][/{color}]",
            f"[{color}]{name}[/{color}]",
            desc
        )

    console.print(table)
    console.print(
        f"  iface:[cyan]{IFACE}[/]  gw:[cyan]{GATEWAY_IP or '?'}[/]  "
        f"dns:{'[green]on[/]' if 'dns' in _stop_events else '[red]off[/]'}  "
        f"jailed:[{'red' if JAILED else 'dim'}]{len(JAILED)}[/]  "
        f"portal:[cyan]{REDIRECT_IP or 'not set'}[/]"
    )
    return Prompt.ask("\n[bold cyan]airjail >[/]").strip().upper()

def run():
    global IFACE, GATEWAY_IP, GATEWAY_MAC

    # ── first-run interface selection ────────────────────────────────────────
    IFACE = pick_interface()
    clear(); banner()
    with console.status(f"[cyan]Auto-detecting gateway on {IFACE}..."):
        GATEWAY_IP, GATEWAY_MAC = get_gateway()
    if GATEWAY_IP:
        console.print(f"[green][✓] Gateway: [bold]{GATEWAY_IP}[/bold]  MAC: {GATEWAY_MAC}[/]")
    else:
        console.print(f"[yellow][!] Could not auto-detect gateway.[/]")
        GATEWAY_IP  = Prompt.ask("[cyan]Enter gateway IP[/]", default="192.168.1.1")
        GATEWAY_MAC = Prompt.ask("[cyan]Enter gateway MAC[/]", default="")
    if SCAPY_OK:
        start_dns_monitor()
        console.print(f"[green][✓] DNS monitor started on {IFACE}[/]")
    subprocess.run(["sysctl","-w","net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    console.print("[green][✓] IP forwarding enabled.[/]")
    time.sleep(1)
    # ────────────────────────────────────────────────────────────────────────

    handlers = {
        "1": menu_scan,
        "2": menu_device_lookup,
        "3": menu_deauth,
        "4": menu_dns_spy,
        "5": menu_bandwidth,
        "6": menu_redirect,
        "7": menu_firewall,
        "8": menu_setup,
    }
    while True:
        ch = main_menu()
        if ch == "Q":
            for ev in _stop_events.values(): ev.set()
            console.print("\n[bold cyan]airjail | 0xb0rn3 — goodbye.[/]\n")
            sys.exit(0)
        fn = handlers.get(ch)
        if fn:
            fn()

if __name__ == "__main__":
    run()
