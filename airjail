# в”Ђв”Ђ LED Engine в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

class LEDEngine:
    """
    MT76 hardware LED control via debugfs register writes.

    Register 0x770 (LED_CFG):
      0x800000 в†’ ON   |  0x820000 в†’ OFF   |  0x840000 в†’ HW blink

    Requires:
      - mt76x2u (or mt76x0u) loaded
      - debugfs mounted at /sys/kernel/debug
      - root privileges (already required by airjail)
    """

    LED_ON  = "0x800000"
    LED_OFF = "0x820000"
    LED_HW  = "0x840000"
    REGIDX  = "0x770"

    def __init__(self):
        self.phy_path:  str | None       = None
        self._enabled:  bool             = False
        self._bkg_thread: threading.Thread | None = None
        self._bkg_stop:   threading.Event          = threading.Event()
        self._init()

    def _init(self):
        """Mount debugfs if needed, then locate the MT76 PHY directory."""
        if not os.path.isdir("/sys/kernel/debug/ieee80211"):
            subprocess.run(["mount", "-t", "debugfs", "none", "/sys/kernel/debug"],
                           stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL)
        paths = glob.glob("/sys/kernel/debug/ieee80211/phy*/mt76")
        for p in paths:
            if os.path.isdir(p):
                self.phy_path = p
                self._enabled = True
                return

    def refresh(self):
        """Re-scan for PHY path (call after driver load)."""
        self.phy_path = None
        self._enabled = False
        self._init()

    def _write(self, val: str):
        if not self._enabled or not self.phy_path:
            return
        try:
            with open(f"{self.phy_path}/regidx", "w") as f:
                f.write(self.REGIDX + "\n")
            with open(f"{self.phy_path}/regval", "w") as f:
                f.write(val + "\n")
        except Exception:
            pass

    def on(self):       self._write(self.LED_ON)
    def off(self):      self._write(self.LED_OFF)
    def hw_blink(self): self._write(self.LED_HW)

    def blink(self, count: int = 3, on_ms: int = 150, off_ms: int = 150):
        for _ in range(count):
            self.on();  time.sleep(on_ms  / 1000)
            self.off(); time.sleep(off_ms / 1000)

    def _stop_bkg(self):
        self._bkg_stop.set()
        if self._bkg_thread and self._bkg_thread.is_alive():
            self._bkg_thread.join(timeout=2)
        self._bkg_stop.clear()
        self._bkg_thread = None

    # в”Ђв”Ђ Named patterns (each fires in a daemon thread to avoid blocking UI) в”Ђв”Ђ

    def boot_sequence(self):
        """Rapid triple-flash в†’ breathing ramp-up в†’ solid ON."""
        if not self._enabled: return
        def _run():
            self.blink(3, 80, 80)
            time.sleep(0.2)
            for d in [0.05, 0.10, 0.18, 0.28, 0.40]:
                self.on();  time.sleep(d)
                self.off(); time.sleep(0.06)
            time.sleep(0.1)
            self.on()
        threading.Thread(target=_run, daemon=True).start()

    def scan_pulse(self):
        """Double sonar-ping Г— 6 вЂ” played during interface/adapter detection."""
        if not self._enabled: return
        def _run():
            for _ in range(6):
                self.on();  time.sleep(0.08)
                self.off(); time.sleep(0.08)
                self.on();  time.sleep(0.08)
                self.off(); time.sleep(0.45)
        threading.Thread(target=_run, daemon=True).start()

    def success(self):
        """5 rapid + 3 medium flashes в†’ solid ON."""
        if not self._enabled: return
        self._stop_bkg()
        def _run():
            self.blink(5, 60, 60)
            time.sleep(0.1)
            self.blink(3, 120, 80)
            time.sleep(0.15)
            self.on()
        threading.Thread(target=_run, daemon=True).start()

    def error(self):
        """SOS morse pattern: В·В·В· вЂ” вЂ” вЂ” В·В·В·"""
        if not self._enabled: return
        self._stop_bkg()
        def _run():
            self.blink(3, 100, 100)   # S
            time.sleep(0.2)
            self.blink(3, 400, 150)   # O
            time.sleep(0.2)
            self.blink(3, 100, 100)   # S
            time.sleep(0.4)
            self.off()
        threading.Thread(target=_run, daemon=True).start()

    def install_start(self):
        """Slow single-pulse loop in background вЂ” runs during driver install."""
        if not self._enabled: return
        self._stop_bkg()
        def _loop():
            while not self._bkg_stop.is_set():
                self.on();  time.sleep(0.12)
                self.off(); time.sleep(0.68)
        self._bkg_thread = threading.Thread(target=_loop, daemon=True)
        self._bkg_thread.start()

    def install_stop(self):
        """Stop install-progress loop."""
        self._stop_bkg()
        self.off()

    def mitm_alert(self):
        """Fast double-strobe Г— 8 в†’ hardware blink вЂ” active threat indicator."""
        if not self._enabled: return
        self._stop_bkg()
        def _run():
            for _ in range(8):
                self.on();  time.sleep(0.04)
                self.off(); time.sleep(0.04)
                self.on();  time.sleep(0.04)
                self.off(); time.sleep(0.18)
            self.hw_blink()
        threading.Thread(target=_run, daemon=True).start()

    def deauth_blast(self):
        """Machine-gun Г— 15 rapid blinks вЂ” packet bombardment burst."""
        if not self._enabled: return
        threading.Thread(target=lambda: self.blink(15, 40, 40), daemon=True).start()

    def jail_flash(self):
        """Aggressive triple-flash when a device is jailed/redirected."""
        if not self._enabled: return
        threading.Thread(target=lambda: self.blink(3, 80, 60), daemon=True).start()

    def unjail_pulse(self):
        """Gentle double long-pulse when a device is released."""
        if not self._enabled: return
        def _run():
            self.on(); time.sleep(0.30); self.off(); time.sleep(0.10)
            self.on(); time.sleep(0.30); self.off()
        threading.Thread(target=_run, daemon=True).start()

    def dns_start(self):
        """Quick double-blink to signal DNS spy activated."""
        if not self._enabled: return
        threading.Thread(target=lambda: self.blink(2, 120, 80), daemon=True).start()

    def monitor_start(self):
        """Slow heartbeat loop in background вЂ” 'listening' mode indicator."""
        if not self._enabled: return
        self._stop_bkg()
        def _loop():
            while not self._bkg_stop.is_set():
                self.on();  time.sleep(0.18)
                self.off(); time.sleep(0.08)
                self.on();  time.sleep(0.06)
                self.off(); time.sleep(1.20)
        self._bkg_thread = threading.Thread(target=_loop, daemon=True)
        self._bkg_thread.start()

    def monitor_stop(self):
        """Stop heartbeat loop."""
        self._stop_bkg()
        self.off()


