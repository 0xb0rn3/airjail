def forensic_event(event_type: str, data: dict):
    _forensic_init()
    entry = {"ts": datetime.now().isoformat(), "type": event_type,
             "iface": IFACE, **data}
    with _forensic_lock:
        try:
            with open(FORENSIC_LOG_FILE, "a") as f:
                f.write(json.dumps(entry) + "\n")
        except Exception:
            pass
    _notify_push(event_type, entry)

def forensic_read(limit: int = 100, event_type: str = "") -> list:
    try:
        lines = Path(FORENSIC_LOG_FILE).read_text().strip().splitlines()
    except Exception:
        return []
    entries = []
    for line in reversed(lines):
        try:
            e = json.loads(line)
            if event_type and e.get("type") != event_type:
                continue
            entries.append(e)
            if len(entries) >= limit:
                break
        except Exception:
            continue
    return entries

def forensic_export_csv(path: str, limit: int = 500) -> bool:
    entries = forensic_read(limit)
    if not entries:
        return False
    try:
        keys = sorted(set(k for e in entries for k in e.keys()))
        with open(path, "w", newline="") as f:
            w = csv.DictWriter(f, fieldnames=keys, extrasaction="ignore")
            w.writeheader()
            w.writerows(entries)
        return True
    except Exception:
        return False

