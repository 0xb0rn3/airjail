                        "pcap":len(_pcap_sessions),"mitm":len(_mitm_sessions),
                        "forensic":forensic_read(10)})
    _dashboard_app = app
    return app

def _start_dash(port=8888):
    global _dashboard_thread, DASHBOARD_PORT
    DASHBOARD_PORT = port
    app = _build_dash()
    if not app: return False
    _dashboard_thread = threading.Thread(
        target=lambda: app.run(host="0.0.0.0",port=port,threaded=True,use_reloader=False),
        daemon=True)
    _dashboard_thread.start()
    return True

