#  SECTION 15 вЂ” TRAFFIC ANALYSIS & PROTOCOL BREAKDOWN  (v2.0)
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

_traffic_stop = threading.Event()
_traffic_thread = None

def _traffic_callback(pkt):
    if not pkt.haslayer(IP): return
    src, dst, size = pkt[IP].src, pkt[IP].dst, len(pkt)
    proto, port = "OTHER", 0
    if pkt.haslayer(TCP):
        port = pkt[TCP].dport
        proto = {80:"HTTP",8080:"HTTP",443:"HTTPS",22:"SSH",21:"FTP",
                 25:"SMTP",587:"SMTP",3389:"RDP"}.get(port, "TCP")
    elif pkt.haslayer(UDP):
        port = pkt[UDP].dport
        proto = {53:"DNS",67:"DHCP",68:"DHCP",5353:"mDNS",1900:"SSDP"}.get(port, "UDP")
    elif pkt.haslayer(ICMP):
        proto = "ICMP"
    TRAFFIC_STATS[src][proto] += size
    TRAFFIC_STATS[dst][f"{proto}_in"] += size
