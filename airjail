def _rogue_cb(pkt):
    if not pkt.haslayer(Dot11Beacon) and not pkt.haslayer(Dot11ProbeResp): return
    bssid = (pkt[Dot11].addr3 or "").lower()
    if not bssid: return
    ssid, channel = "", "?"
    try:
        elt = pkt[Dot11Elt]
        while elt:
            if elt.ID == 0: ssid = elt.info.decode(errors="ignore"); break
            elt = elt.payload.getlayer(Dot11Elt)
    except Exception: pass
    try:
        elt = pkt[Dot11Elt]
        while elt:
            if elt.ID == 3: channel = str(elt.info[0]); break
            elt = elt.payload.getlayer(Dot11Elt)
    except Exception: pass
    sig = "?"
    if pkt.haslayer(RadioTap):
        try: sig = pkt[RadioTap].dBm_AntSignal
        except Exception: pass
    cap = pkt.sprintf("{Dot11Beacon:%Dot11Beacon.cap%}{Dot11ProbeResp:%Dot11ProbeResp.cap%}")
    enc = "WEP/WPA" if "privacy" in cap.lower() else "OPEN"
    now = datetime.now().strftime("%H:%M:%S")
    vendor = mac_vendor(bssid) if MANUF_OK else "?"
    is_new = bssid not in KNOWN_APS
    prev = KNOWN_APS.get(bssid)
    if is_new:
        KNOWN_APS[bssid] = {"ssid":ssid,"channel":channel,"enc":enc,
                             "first_seen":now,"last_seen":now,"vendor":vendor,"signal":sig}
    else:
        KNOWN_APS[bssid]["last_seen"] = now; KNOWN_APS[bssid]["signal"] = sig
    alerts = []
    if ssid:
        twins = [b for b, i in KNOWN_APS.items() if i["ssid"]==ssid and b!=bssid]
        if twins:
            alerts.append({"bssid":bssid,"ssid":ssid,"channel":channel,"time":now,"signal":sig,
                           "reason":f"Evil Twin вЂ” '{ssid}' also on {', '.join(twins[:3])}"})
    if prev and prev["channel"] != channel and prev["channel"] != "?":
        alerts.append({"bssid":bssid,"ssid":ssid,"channel":channel,"time":now,"signal":sig,
                       "reason":f"Channel change: {prev['channel']} в†’ {channel}"})
    sus = ("free wifi","open wifi","xfinity","attwifi","linksys","netgear","default")
    if ssid.lower().strip() in sus and is_new:
        alerts.append({"bssid":bssid,"ssid":ssid,"channel":channel,"time":now,"signal":sig,
                       "reason":f"Suspicious SSID: '{ssid}'"})
    for a in alerts:
        ROGUE_ALERTS.append(a); forensic_event("rogue_ap", a); LED.mitm_alert()

