def _detect_pm():
    for pm in ("pacman", "apt", "dnf"):
        if shutil.which(pm):
            return pm
    return None


def _distro_name():
    try:
        with open("/etc/os-release") as f:
            for line in f:
                if line.startswith("NAME="):
                    return line.split("=")[1].strip().strip('"')
    except Exception:
        pass
    return platform.system()


class _Spinner:
    _frames = ["в ‹","в ™","в №","в ё","в ј","в ґ","в ¦","в §","в ‡","в Џ"]

    def __init__(self, msg):
        self.msg   = msg
        self._stop = threading.Event()
        self._t    = threading.Thread(target=self._run, daemon=True)

    def _run(self):
        i = 0
        while not self._stop.is_set():
            print(f"\r\033[36m{self._frames[i % len(self._frames)]}\033[0m {self.msg}",
                  end="", flush=True)
            time.sleep(0.08)
            i += 1

    def start(self): self._t.start(); return self

    def stop(self, ok=True):
        self._stop.set()
        sym = "\033[32mвњ“\033[0m" if ok else "\033[31mвњ—\033[0m"
        print(f"\r{sym} {self.msg}       ")


def _install_sys_pkgs(pm, pkgs):
    if pm == "pacman":
        cmd = ["pacman", "-S", "--noconfirm", "--needed"] + pkgs
    elif pm == "apt":
        subprocess.run(["apt", "update", "-qq"], check=False,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        cmd = ["apt", "install", "-y", "-qq"] + pkgs
    elif pm == "dnf":
        cmd = ["dnf", "install", "-y", "-q"] + pkgs
    else:
        return False
    sp = _Spinner(f"Installing system packages via {pm}...").start()
    r  = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    sp.stop(r.returncode == 0)
    return r.returncode == 0


def _install_py_pkg(pkg):
    flags = ["--break-system-packages"] if _detect_pm() in ("apt", "dnf") else []
    r = subprocess.run(
        [sys.executable, "-m", "pip", "install", pkg, "-q"] + flags,
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    )
    return r.returncode == 0


def bootstrap():
    missing_py  = []
    missing_sys = []

    for pkg in _PY_PKGS:
        try:
            __import__(pkg.split("[")[0])
        except ImportError:
            missing_py.append(pkg)

    for tool in ("nmap", "airmon-ng", "iptables", "iw"):
        if not shutil.which(tool):
            missing_sys.append(tool)

    if not missing_py and not missing_sys:
        return

    pm     = _detect_pm()
    distro = _distro_name()

    print("\033[1;36m")
    print("  в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—")
    print("  в•‘        airjail вЂ” dependency check        в•‘")
    print("  в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\033[0m")
    print(f"\033[33m  Distro : {distro}")
    print(f"  PM     : {pm or 'not detected'}\033[0m\n")

    if missing_sys and pm:
        print(f"\033[33m  Missing system tools: {', '.join(missing_sys)}\033[0m")
        _install_sys_pkgs(pm, _SYS_PKGS.get(pm, []))

    for pkg in missing_py:
        sp = _Spinner(f"pip install {pkg}").start()
        ok = _install_py_pkg(pkg)
        sp.stop(ok)
        if not ok:
            print(f"\033[31m  Failed to install {pkg}.\033[0m")

    print()


