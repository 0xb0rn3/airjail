def _auto_jail(ip: str, reason: str):
    mac = next((d["mac"].lower() for d in _scan_results if d["ip"]==ip), "unknown")
    if mac in JAILED: return
    if REDIRECT_IP: _redirect_on(ip, REDIRECT_IP, REDIRECT_PORT)
    JAILED[mac] = {"ip":ip, "reason":f"[AUTO] {reason}",
                    "time":datetime.now().strftime("%Y-%m-%d %H:%M:%S")}
    LED.jail_flash(); session_save()
    forensic_event("auto_quarantine", {"ip":ip,"mac":mac,"reason":reason})

def _quar_enforce():
    while not _quar_stop.is_set():
        for rule in QUARANTINE_RULES:
            if not rule.get("enabled"): continue
            try:
                rt = rule["type"]
                if rt == "bandwidth":
                    thresh = rule.get("threshold_mb",500)*1_048_576
                    for ip, bw in BW_STATS.items():
                        if bw["rx"]+bw["tx"] > thresh:
                            _auto_jail(ip, f"BW>{rule['threshold_mb']}MB")
                elif rt == "time":
                    now_h = datetime.now().hour
                    s, e = rule.get("start_hour",23), rule.get("end_hour",6)
                    in_w = (now_h>=s or now_h<e) if s>e else (s<=now_h<e)
                    if in_w:
                        for mac in rule.get("targets",[]):
                            if mac.lower() not in JAILED:
                                dev = next((d for d in _scan_results if d["mac"].lower()==mac.lower()), None)
                                if dev: _auto_jail(dev["ip"], f"Curfew {s}:00-{e}:00")
                elif rt == "protocol":
                    for ip, protos in TRAFFIC_STATS.items():
                        for bp in rule.get("blocked_protocols",[]):
                            if protos.get(bp,0)>0: _auto_jail(ip, f"Blocked: {bp}")
                elif rt == "dns":
                    for mac, domains in DNS_LOG.items():
                        for dom in domains[-20:]:
                            for bd in rule.get("blocked_domains",[]):
                                if bd.lower() in dom.lower():
                                    dev = next((d for d in _scan_results if d["mac"].lower()==mac), None)
                                    if dev and dev["mac"].lower() not in JAILED:
                                        _auto_jail(dev["ip"], f"Blocked DNS: {dom}")
            except Exception: continue
        _quar_stop.wait(timeout=10)

