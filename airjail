def _full_cleanup():
    """Flush all iptables rules added by airjail and restore sane state."""
    console.print("\n[yellow][*] Cleaning up iptables rules...[/]")
    # flush NAT PREROUTING (all redirects)
    subprocess.run(["iptables", "-t", "nat", "-F", "PREROUTING"],
                   check=False, stderr=subprocess.DEVNULL)
    # flush FORWARD chain
    subprocess.run(["iptables", "-F", "FORWARD"],
                   check=False, stderr=subprocess.DEVNULL)
    # stop all background threads
    for ev in _stop_events.values():
        ev.set()
    # stop any active MITM
    for ip in list(_mitm_sessions.keys()):
        _mitm_stop(ip)
    # save session so jailed list survives restart
    session_save()
    console.print("[green][вњ“] Cleanup complete.[/]")


def _signal_handler(sig, frame):
    _full_cleanup()
    console.print("\n[bold cyan]airjail | 0xb0rn3 вЂ” goodbye.[/]\n")
    sys.exit(0)


signal.signal(signal.SIGINT,  _signal_handler)
signal.signal(signal.SIGTERM, _signal_handler)


