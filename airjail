def scan_network(subnet=None, silent=False):
    if not SCAPY_OK:
        console.print("[red]Scapy unavailable[/]"); return []
    if subnet is None:
        subnet = get_local_subnet()
    if not silent:
        console.print(f"\n[cyan][*] Scanning {subnet} on [bold]{IFACE}[/bold]...[/]")
    try:
        ans, _ = srp(Ether(dst="ff:ff:ff:ff:ff:ff") / ARP(pdst=subnet),
                     iface=IFACE, timeout=3, verbose=False)
    except Exception as e:
        console.print(f"[red]Scan error: {e}[/]"); return []

    results  = []
    spoofed  = []
    for _, pkt in ans:
        ip  = pkt[ARP].psrc
        mac = pkt[ARP].hwsrc
        # ARP change detection вЂ” flag if IP now maps to different MAC
        prev_mac = _arp_table.get(ip)
        if prev_mac and prev_mac.lower() != mac.lower():
            spoofed.append((ip, prev_mac, mac))
        _arp_table[ip] = mac
        results.append({"ip": ip, "mac": mac})

    if spoofed:
        for ip, old, new in spoofed:
            console.print(
                f"[bold red][вљ ] ARP CHANGE DETECTED: {ip} was {old} в†’ now {new} "
                f"(possible ARP spoofing / MAC change)[/]")

    return results


