# ── Adapter detection ─────────────────────────────────────────────────────────

def detect_usb_adapter(silent: bool = False) -> dict | None:
    """
    Scan `lsusb` output against ADAPTER_DB.
    Populates the ADAPTER_* globals and wires up LED if the adapter supports it.
    Returns a dict with adapter info, or None if nothing matched.
    """
    global ADAPTER_USB_ID, ADAPTER_CHIPSET, ADAPTER_VENDOR
    global ADAPTER_DRIVER, ADAPTER_INSTALL, ADAPTER_LED

    try:
        usb_out = subprocess.check_output(["lsusb"], text=True,
                                          stderr=subprocess.DEVNULL)
    except Exception:
        if not silent:
            pass  # lsusb not available — skip silently
        return None

    for usb_id, info in ADAPTER_DB.items():
        if usb_id.lower() in usb_out.lower():
            chipset, vendor, driver, method, led = info
            ADAPTER_USB_ID  = usb_id
            ADAPTER_CHIPSET = chipset
            ADAPTER_VENDOR  = vendor
            ADAPTER_DRIVER  = driver
            ADAPTER_INSTALL = method
            ADAPTER_LED     = led
            # Re-init LED engine now that we know LED capability
            if led:
                LED.refresh()
            return {
                "usb_id": usb_id, "chipset": chipset, "vendor": vendor,
                "driver": driver, "method": method, "led": led,
                "lsusb_line": next(
                    (l for l in usb_out.splitlines() if usb_id.lower() in l.lower()),
                    "—"
                ),
            }

    # Fuzzy fallback: detect any known vendor prefix
    for prefix, (chipset, vendor) in {
        "0e8d:": ("MT76xx", "MediaTek"),
        "0bda:": ("Realtek", "Realtek"),
        "148f:": ("Ralink/MT", "Ralink"),
        "0cf3:": ("AR9xxx", "Atheros"),
    }.items():
        if prefix in usb_out.lower():
            if not silent:
                pass
            ADAPTER_CHIPSET = chipset
            ADAPTER_VENDOR  = vendor
            ADAPTER_LED     = False
            return {
                "usb_id": f"{prefix}????", "chipset": chipset,
                "vendor": vendor, "driver": "unknown",
                "method": "unknown", "led": False,
                "lsusb_line": "unknown — USB ID not in database",
            }

    return None


# ── Driver installation ───────────────────────────────────────────────────────

def _git_dkms(repo_url: str, dir_name: str, script: str = "install-driver.sh") -> bool:
    """Clone repo into /tmp and run its DKMS install script."""
    build = f"/tmp/airjail_drv_{dir_name}"
    try:
        if os.path.isdir(build):
            subprocess.run(["rm", "-rf", build], check=False)
        subprocess.run(["git", "clone", "--depth=1", repo_url, build], check=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        inst = os.path.join(build, script)
        os.chmod(inst, 0o755)
        subprocess.run(["sudo", inst], check=True, cwd=build)
        subprocess.run(["rm", "-rf", build], check=False)
        return True
    except Exception as e:
        return False

def _modprobe(module: str, deps: list | None = None) -> bool:
    """Load kernel module (and optional dependencies)."""
    for m in (deps or []) + [module]:
        subprocess.run(["sudo", "modprobe", m],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    time.sleep(1)
    try:
        out = subprocess.check_output(["lsmod"], text=True)
        return module in out
    except Exception:
        return False

def install_adapter_driver(console_obj) -> bool:
    """
    Install the driver for the currently detected adapter.
    Uses ADAPTER_INSTALL to dispatch to the correct method.
    Drives the LED install-progress pattern during the build.
    """
    if not ADAPTER_INSTALL:
        console_obj.print("[red]No adapter detected — run detection first.[/]")
        return False

    method = ADAPTER_INSTALL
    driver = ADAPTER_DRIVER or ""

    LED.install_start()

    ok = False
    try:
        if method == "kernel":
            dep_map = {
                "mt76x2u":   ["mt76x2_common", "mt76_usb", "mt76"],
                "mt76x0u":   ["mt76x0_common", "mt76_usb", "mt76"],
                "mt7921u":   ["mt7921_common",  "mt76_connac_lib", "mt76_usb", "mt76"],
                "rt2800usb": ["rt2800lib", "rt2x00usb", "rt2x00lib"],
                "ath9k_htc": ["ath9k_common", "ath"],
                "r8188eu":   [],
                "mt7601u":   [],
            }
            deps = dep_map.get(driver, [])
            ok = _modprobe(driver, deps)

        elif method == "morrownr_7612u":
            # Try in-kernel first (Linux 4.19+)
            if _modprobe("mt76x2u", ["mt76x2_common", "mt76_usb", "mt76"]):
                ok = True
            else:
                console_obj.print("[yellow]  In-kernel mt76x2u unavailable — building from source...[/]")
                ok = _git_dkms("https://github.com/morrownr/7612u.git", "7612u")

        elif method == "rtl8812au":
            ok = _git_dkms("https://github.com/aircrack-ng/rtl8812au.git", "rtl8812au")

        elif method == "rtl8812bu":
            ok = _git_dkms("https://github.com/morrownr/88x2bu-20210629.git", "88x2bu")

        elif method == "rtl8814au":
            ok = _git_dkms("https://github.com/morrownr/8814au.git", "8814au")

        elif method == "rtl8821cu":
            ok = _git_dkms("https://github.com/morrownr/8821cu-20210118.git", "8821cu")

        elif method == "ath9k_htc":
            # Install firmware package then modprobe
            pm = _detect_pm()
            fw_pkg = {
                "apt": "firmware-atheros", "pacman": "linux-firmware",
                "dnf": "linux-firmware",
            }.get(pm, "linux-firmware")
            subprocess.run(["sudo", pm, "install", "-y", fw_pkg],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            ok = _modprobe("ath9k_htc", ["ath9k_common", "ath"])

        else:
            console_obj.print(f"[red]Unknown install method: {method}[/]")

    except Exception as ex:
        console_obj.print(f"[red]Install error: {ex}[/]")
        ok = False

    LED.install_stop()

    if ok:
        LED.refresh()   # PHY may now be available
        LED.success()
    else:
        LED.error()

    return ok


