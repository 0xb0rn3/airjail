# ── TTL → OS heuristic ───────────────────────────────────────────────────────
def _os_from_ttl(ttl: int) -> str:
    if   ttl >= 128: return "Windows"
    elif ttl >=  64: return "Linux/macOS"
    elif ttl >=  32: return "Network device"
    else:            return "Unknown"

# ── Signal strength for associated STAs via iw ───────────────────────────────
def _signal_map() -> dict:
    """Return {mac_lower: signal_dbm} via `iw dev <IFACE> station dump`."""
    smap = {}
    try:
        out = subprocess.check_output(
            ["iw", "dev", IFACE, "station", "dump"],
            text=True, stderr=subprocess.DEVNULL
        )
        cur_mac = None
        for line in out.splitlines():
            line = line.strip()
            if line.startswith("Station"):
                cur_mac = line.split()[1].lower()
            elif line.startswith("signal:") and cur_mac:
                m = re.search(r"(-?\d+)", line)
                if m:
                    smap[cur_mac] = int(m.group(1))
    except Exception:
        pass
    return smap

# ── Quick port probe for device classification ───────────────────────────────
_PROBE_PORTS = (22, 23, 80, 443, 554, 8080, 9100)

def _quick_ports(ip: str) -> list:
    """Non-blocking SYN-connect probe on common ports. Returns sorted open list."""
    open_ports = []
    lock = threading.Lock()

    def _probe(p):
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(0.35)
            if s.connect_ex((ip, p)) == 0:
                with lock: open_ports.append(p)
            s.close()
        except Exception:
            pass

    workers = [threading.Thread(target=_probe, args=(p,), daemon=True)
               for p in _PROBE_PORTS]
    for t in workers: t.start()
    for t in workers: t.join(timeout=0.7)
    return sorted(open_ports)

# ── Device classification from vendor string + open ports ────────────────────
def _classify_device(vendor: str, ports: list) -> str:
    v = vendor.lower()
    if any(k in v for k in ("raspberry", "arduino")):              return "🍓 IoT/SBC"
    if "apple" in v:                                               return "🍎 Apple"
    if any(k in v for k in ("samsung", "xiaomi", "oppo",
                              "huawei", "oneplus", "realme")):      return "📱 Phone"
    if any(k in v for k in ("cisco", "ubiquiti", "mikrotik",
                              "tp-link", "netgear", "asus",
                              "linksys", "draytek", "edgecore")):   return "🌐 Router/AP"
    if any(k in v for k in ("canon", "epson", "hp inc", "brother",
                              "ricoh", "xerox", "kyocera")):        return "🖨 Printer"
    if 9100 in ports:                                              return "🖨 Printer"
    if 554  in ports:                                              return "📷 Camera"
    if 23   in ports:                                              return "🔌 Network"
    if any(p in ports for p in (22, 80, 443)):                     return "💻 Computer"
    return "❓ Unknown"

# ── Core scanner: ARP sweep + ICMP ping fallback, threaded ───────────────────
def scan_network(subnet=None, silent=False) -> list:
    """
    Multi-method LAN scanner:
      1. ARP broadcast sweep (primary — fast, reliable)
      2. ICMP ping sweep for hosts that ignore ARP (threaded, /24 only)
      3. TTL-based OS fingerprint (async best-effort)
      4. ARP-change detection (MitM / rogue device alert)
    Returns list of dicts: {ip, mac, ttl, os_guess}.
    """
    global _arp_table, _scan_results

    if not SCAPY_OK:
        console.print("[red]Scapy unavailable — cannot scan.[/]"); return []

    if subnet is None:
        subnet = get_local_subnet()
    if not silent:
        console.print(f"\n[cyan][*] Scanning [bold]{subnet}[/bold] on [bold]{IFACE}[/bold]...[/]")

    # ─── 1. ARP sweep ────────────────────────────────────────────────────────
    try:
        ans, _ = srp(
            Ether(dst="ff:ff:ff:ff:ff:ff") / ARP(pdst=subnet),
            iface=IFACE, timeout=3, verbose=False, retry=1
        )
    except Exception as e:
        if not silent: console.print(f"[red]ARP error: {e}[/]")
        ans = []

    arp_hosts = {}   # ip → mac_lower
    for _, pkt in ans:
        arp_hosts[pkt[ARP].psrc] = pkt[ARP].hwsrc.lower()

    # ─── 2. ICMP ping for non-ARP hosts ─────────────────────────────────────
    ping_results = {}   # ip → ttl

    try:
        import ipaddress as _ipmod
        net   = _ipmod.ip_network(subnet, strict=False)
        hosts = [str(h) for h in net.hosts()]
    except Exception:
        hosts = []

    missed = [h for h in hosts if h not in arp_hosts and len(hosts) <= 512]

    _ping_lock = threading.Lock()

    def _icmp_probe(ip):
        from scapy.all import IP as _IP, ICMP as _ICMP, sr1 as _sr1
        try:
            r = _sr1(_IP(dst=ip)/_ICMP(), timeout=0.8, verbose=False, iface=IFACE)
            if r and r.haslayer(_IP):
                with _ping_lock:
                    ping_results[ip] = r[_IP].ttl
        except Exception:
            pass

    if missed:
        if not silent:
            console.print(f"[dim]  ICMP probing {len(missed)} non-ARP hosts...[/]")
        workers = [threading.Thread(target=_icmp_probe, args=(h,), daemon=True)
                   for h in missed]
        for t in workers: t.start()
        for t in workers: t.join(timeout=4.0)

    # ─── 3. ARP-change detection ──────────────────────────────────────────────
    for ip, mac in arp_hosts.items():
        prev = _arp_table.get(ip)
        if prev and prev != mac:
            console.print(
                f"\n[bold red][⚠] ARP CHANGE: {ip} was {prev} → now {mac} "
                f"— possible spoofing![/]"
            )
    _arp_table.update(arp_hosts)

    # ─── 4. Build unified result list ─────────────────────────────────────────
    results  = []
    seen_ips = set()

    for ip, mac in arp_hosts.items():
        results.append({"ip": ip, "mac": mac, "ttl": None, "os_guess": ""})
        seen_ips.add(ip)

    for ip, ttl in ping_results.items():
        if ip not in seen_ips:
            results.append({
                "ip": ip, "mac": "ff:ff:ff:ff:ff:ff",
                "ttl": ttl, "os_guess": _os_from_ttl(ttl)
            })
            seen_ips.add(ip)

    # Fill TTL for ARP hosts (async, best-effort)
    def _fill_ttl(entry):
        from scapy.all import IP as _IP, ICMP as _ICMP, sr1 as _sr1
        try:
            r = _sr1(_IP(dst=entry["ip"])/_ICMP(), timeout=0.7,
                     verbose=False, iface=IFACE)
            if r and r.haslayer(_IP):
                entry["ttl"]      = r[_IP].ttl
                entry["os_guess"] = _os_from_ttl(r[_IP].ttl)
        except Exception:
            pass

    ttl_workers = [threading.Thread(target=_fill_ttl, args=(e,), daemon=True)
                   for e in results if e["ttl"] is None]
    for t in ttl_workers: t.start()
    for t in ttl_workers: t.join(timeout=3.0)

    _scan_results[:] = results   # keep deauth / port scan pickers in sync
    return results


