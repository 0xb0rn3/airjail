def session_save():
    """Persist JAILED dict to disk."""
    try:
        SESSION_FILE.parent.mkdir(parents=True, exist_ok=True)
        with open(SESSION_FILE, "w") as f:
            json.dump(JAILED, f, indent=2)
    except Exception as e:
        console.print(f"[yellow][!] Could not save session: {e}[/]")


def session_load():
    """Restore JAILED dict from disk if it exists."""
    global JAILED
    if SESSION_FILE.exists():
        try:
            with open(SESSION_FILE) as f:
                data = json.load(f)
            JAILED.update(data)
            console.print(f"[cyan][*] Restored {len(data)} jailed entries from previous session.[/]")
        except Exception:
            pass


