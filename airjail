def _run_nmap(target_ip: str):
    """Run nmap against target and render results in a Rich table."""
    if not shutil.which("nmap"):
        console.print("[red]nmap not found. Install it first.[/]")
        return

    console.print(f"\n[cyan][*] Running nmap on {target_ip}...[/]")

    presets = {
        "1": ("-sV -T4 --open -p-",          "Full port + service version scan"),
        "2": ("-sV -T4 --open --top-ports 1000", "Top 1000 ports (faster)"),
        "3": ("-sV -sC -T4 --open -p-",       "Full + default scripts"),
        "4": ("-sU -T4 --top-ports 100",       "Top 100 UDP ports"),
        "5": ("",                              "Custom (enter flags manually)"),
    }
    console.print("\n[bold]Scan presets:[/]")
    for k, (flags, desc) in presets.items():
        console.print(f"  [yellow][{k}][/] {desc}")

    choice = Prompt.ask("[cyan]Select preset[/]", default="2")
    if choice == "5":
        flags = Prompt.ask("[cyan]nmap flags[/]", default="-sV -T4 --open")
    else:
        flags = presets.get(choice, presets["2"])[0]

    cmd = f"nmap {flags} -oN - {target_ip}"
    console.print(f"[dim]Running: {cmd}[/]\n")

    try:
        result = subprocess.run(
            cmd.split(), text=True,
            capture_output=True, timeout=300
        )
        if result.stdout:
            # Parse and render open ports in a table
            table = Table(
                title=f"[bold cyan]nmap в†’ {target_ip}[/]",
                box=box.ROUNDED, border_style="cyan", show_lines=True)
            table.add_column("Port",     style="yellow")
            table.add_column("State",    style="green")
            table.add_column("Service",  style="cyan")
            table.add_column("Version",  style="magenta")

            port_re = re.compile(
                r"^(\d+/\w+)\s+(open\S*)\s+(\S+)\s*(.*)", re.M)
            matches = port_re.findall(result.stdout)
            if matches:
                for port, state, svc, ver in matches:
                    table.add_row(port, state, svc, ver.strip())
                console.print(table)
            else:
                # Fall back to raw output
                console.print(result.stdout)
        if result.returncode != 0 and result.stderr:
            console.print(f"[red]{result.stderr}[/]")
    except subprocess.TimeoutExpired:
        console.print("[red]Scan timed out (300s).[/]")
    except Exception as e:
        console.print(f"[red]Error: {e}[/]")


