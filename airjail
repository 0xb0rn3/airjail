def menu_setup():
    global IFACE, GATEWAY_IP, GATEWAY_MAC, REDIRECT_IP, REDIRECT_PORT

    IFACE = pick_interface()

    clear(); banner()
    console.print("[bold cyan]── Setup ──[/]\n")
    console.print(f"[green][✓] Interface: [bold]{IFACE}[/bold][/]\n")

    with console.status("[cyan]Detecting gateway..."):
        GATEWAY_IP, GATEWAY_MAC = get_gateway()

    if GATEWAY_IP:
        console.print(f"[green][✓] Gateway: {GATEWAY_IP}  MAC: {GATEWAY_MAC}[/]")
    else:
        GATEWAY_IP  = Prompt.ask("[yellow]Enter gateway IP[/]", default="192.168.1.1")
        GATEWAY_MAC = Prompt.ask("[yellow]Enter gateway MAC[/]", default="")

    portal = Prompt.ask("[cyan]Captive portal IP (blank to skip)[/]", default="")
    if portal:
        REDIRECT_IP   = portal
        REDIRECT_PORT = int(Prompt.ask("[cyan]Portal port[/]", default="80"))

    if SCAPY_OK:
        start_dns_monitor()
        console.print("[green][✓] DNS monitor started.[/]")

    subprocess.run(["sysctl","-w","net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    console.print("[green][✓] IP forwarding enabled.[/]")

    console.print(f"""
[bold green]Setup complete![/]
  Interface  : [cyan]{IFACE}[/]
  Gateway    : [cyan]{GATEWAY_IP}  ({GATEWAY_MAC})[/]
  Portal     : [cyan]{REDIRECT_IP or 'not set'}[/]
  DNS Monitor: [green]running[/]
""")
    input("Enter to continue...")

