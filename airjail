def _iw_get_mode(iface: str) -> str:
    try:
        out = subprocess.check_output(["iw","dev",iface,"info"],
                                      stderr=subprocess.DEVNULL, text=True)
        m = re.search(r"type (\S+)", out)
        return m.group(1).lower() if m else "unknown"
    except Exception:
        return "unknown"

def _list_wireless_ifaces() -> list:
    ifaces = []
    try:
        out = subprocess.check_output(["iw","dev"],
                                      stderr=subprocess.DEVNULL, text=True)
        cur = {}
        for line in out.splitlines():
            line = line.strip()
            if line.startswith("Interface"):
                if cur: ifaces.append(cur)
                cur = {"name":line.split()[1],"mode":"unknown",
                       "addr":"--","ssid":"--","channel":"--"}
            elif line.startswith("type") and cur:
                cur["mode"] = line.split()[1].lower()
            elif line.startswith("addr") and cur:
                cur["addr"] = line.split()[1]
            elif line.startswith("ssid") and cur:
                cur["ssid"] = " ".join(line.split()[1:]) or "--"
            elif line.startswith("channel") and cur:
                cur["channel"] = line.split()[1]
        if cur: ifaces.append(cur)
    except Exception:
        pass
    if not ifaces:
        for name in os.listdir("/sys/class/net"):
            if os.path.exists(f"/sys/class/net/{name}/wireless"):
                ifaces.append({"name":name,"mode":_iw_get_mode(name),
                               "addr":"--","ssid":"--","channel":"--"})
    return ifaces

def _kill_interfering() -> list:
    killed = []
    for proc in ("wpa_supplicant","NetworkManager","dhclient","dhcpcd"):
        r = subprocess.run(["pkill","-x",proc],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if r.returncode == 0:
            killed.append(proc)
    return killed

def _enable_monitor(iface: str, channel: int = 0):
    # airmon-ng preferred
    if shutil.which("airmon-ng"):
        try:
            _kill_interfering()
            args = ["airmon-ng","start",iface]
            if channel: args.append(str(channel))
            out = subprocess.check_output(args, stderr=subprocess.STDOUT,
                                          text=True, timeout=20)
            m = re.search(r"enabled.+?on\s+\[?phy\d+\]?(\w+)", out, re.IGNORECASE)
            if m: return m.group(1)
            mon = iface + "mon"
            if os.path.exists(f"/sys/class/net/{mon}"): return mon
        except Exception:
            pass
    # iw fallback
    try:
        subprocess.run(["ip","link","set",iface,"down"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["iw",iface,"set","type","monitor"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
        subprocess.run(["ip","link","set",iface,"up"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if channel:
            subprocess.run(["iw",iface,"set","channel",str(channel)],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return iface
    except Exception:
        return None

def _disable_monitor(iface: str, original_name: str | None = None) -> bool:
    if shutil.which("airmon-ng"):
        try:
            subprocess.run(["airmon-ng","stop",iface],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
            return True
        except Exception:
            pass
    target = original_name or iface
    try:
        subprocess.run(["ip","link","set",iface,"down"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["iw",iface,"set","type","managed"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
        subprocess.run(["ip","link","set",target,"up"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception:
        return False

_hop_stop   = threading.Event()
_hop_thread_ref: list = [None]   # mutable container so lambdas can write it

def _start_hop(iface: str, channels: list | None = None, interval: float = 0.5) -> None:
    if channels is None:
        channels = list(range(1,14)) + [36,40,44,48,52,56,60,64]
    _hop_stop.clear()
    def _loop():
        while not _hop_stop.is_set():
            for ch in channels:
                if _hop_stop.is_set(): break
                subprocess.run(["iw",iface,"set","channel",str(ch)],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                _hop_stop.wait(timeout=interval)
    t = threading.Thread(target=_loop, daemon=True)
    _hop_thread_ref[0] = t
    t.start()

def _stop_hop() -> None:
    _hop_stop.set()
    t = _hop_thread_ref[0]
    if t and t.is_alive():
        t.join(timeout=2)
    _hop_thread_ref[0] = None
    _hop_stop.clear()

def _pick_monitor_iface() -> str | None:
    global MON_IFACE
    if MONITOR_IFACES:
        sessions = [(phy, sess["mon_iface"]) for phy, sess in MONITOR_IFACES.items()]
        if len(sessions) == 1:
            MON_IFACE = sessions[0][1]
            return MON_IFACE
        for i, (phy, mon) in enumerate(sessions, 1):
            console.print(f"  [{i}] {mon}  (phy: {phy})")
        ch = Prompt.ask("[cyan]Select #[/]", default="1").strip()
        if ch.isdigit() and 1 <= int(ch) <= len(sessions):
            MON_IFACE = sessions[int(ch)-1][1]
        else:
            MON_IFACE = sessions[0][1]
        return MON_IFACE
    for w in _list_wireless_ifaces():
        if w["mode"] == "monitor":
            MON_IFACE = w["name"]
            return MON_IFACE
    console.print("[yellow]No monitor interface active. Use [bold][W] Monitor Mode[/bold].[/]")
    manual = Prompt.ask("[dim]Enter monitor iface manually (blank=cancel)[/]",
                        default="").strip()
    if manual: MON_IFACE = manual
    return manual or None


