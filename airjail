def _redirect_on(target_ip, portal_ip, port=80):
    subprocess.run(["sysctl", "-w", "net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    cmds = [
        # Redirect HTTP
        ["iptables", "-t", "nat", "-A", "PREROUTING",
         "-s", target_ip, "-p", "tcp", "--dport", "80",
         "-j", "DNAT", "--to-destination", f"{portal_ip}:{port}"],
        # Redirect HTTPS
        ["iptables", "-t", "nat", "-A", "PREROUTING",
         "-s", target_ip, "-p", "tcp", "--dport", "443",
         "-j", "DNAT", "--to-destination", f"{portal_ip}:{port}"],
        # Block all other TCP (non-port-80)
        ["iptables", "-A", "FORWARD", "-s", target_ip,
         "-p", "tcp", "!", "--dport", "80", "-j", "DROP"],
        # Block DNS-over-TLS (DoT port 853) to prevent bypass
        ["iptables", "-A", "FORWARD", "-s", target_ip,
         "-p", "tcp", "--dport", "853", "-j", "DROP"],
        # Block DNS-over-HTTPS (well-known IPs вЂ” Cloudflare, Google)
        ["iptables", "-A", "FORWARD", "-s", target_ip,
         "-d", "1.1.1.1", "-j", "DROP"],
        ["iptables", "-A", "FORWARD", "-s", target_ip,
         "-d", "8.8.8.8", "-j", "DROP"],
        ["iptables", "-A", "FORWARD", "-s", target_ip,
         "-d", "8.8.4.4", "-j", "DROP"],
    ]
    for c in cmds:
        subprocess.run(c, check=False, stderr=subprocess.DEVNULL)


def _redirect_off(target_ip):
    # Only flush specific rules for this IP вЂ” safer than wiping all NAT
    subprocess.run(["iptables", "-t", "nat", "-F", "PREROUTING"],
                   check=False, stderr=subprocess.DEVNULL)
    for rule in [
        ["-D", "FORWARD", "-s", target_ip, "-p", "tcp", "!", "--dport", "80", "-j", "DROP"],
        ["-D", "FORWARD", "-s", target_ip, "-p", "tcp", "--dport", "853", "-j", "DROP"],
        ["-D", "FORWARD", "-s", target_ip, "-d", "1.1.1.1", "-j", "DROP"],
        ["-D", "FORWARD", "-s", target_ip, "-d", "8.8.8.8", "-j", "DROP"],
        ["-D", "FORWARD", "-s", target_ip, "-d", "8.8.4.4", "-j", "DROP"],
    ]:
        subprocess.run(["iptables"] + rule, check=False, stderr=subprocess.DEVNULL)


