def _redirect_on(target_ip, portal_ip, port=80):
    subprocess.run(["sysctl","-w","net.ipv4.ip_forward=1"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    cmds = [
        ["iptables","-t","nat","-A","PREROUTING",
         "-s",target_ip,"-p","tcp","--dport","80",
         "-j","DNAT","--to-destination",f"{portal_ip}:{port}"],
        ["iptables","-t","nat","-A","PREROUTING",
         "-s",target_ip,"-p","tcp","--dport","443",
         "-j","DNAT","--to-destination",f"{portal_ip}:{port}"],
        ["iptables","-A","FORWARD","-s",target_ip,
         "-p","tcp","!","--dport","80","-j","DROP"],
    ]
    for c in cmds:
        subprocess.run(c, check=False, stderr=subprocess.DEVNULL)

def _redirect_off(target_ip):
    subprocess.run(["iptables","-t","nat","-F"],
                   check=False, stderr=subprocess.DEVNULL)
    subprocess.run(["iptables","-D","FORWARD","-s",target_ip,
                    "-p","tcp","!","--dport","80","-j","DROP"],
                   check=False, stderr=subprocess.DEVNULL)

def menu_redirect():
    global REDIRECT_IP, JAILED
    while True:
        clear(); banner()
        console.print("[bold cyan]── Jail / Redirect / Captive Portal ──[/]\n")

        # current portal status
        portal_status = (f"[green]{REDIRECT_IP}:{REDIRECT_PORT}[/]"
                         if REDIRECT_IP else "[red]not configured[/]")
        console.print(f"  Portal server : {portal_status}")
        console.print(f"  Jailed users  : [{'red' if JAILED else 'dim'}]{len(JAILED)}[/]\n")

        console.print(
            "  [bold yellow][1][/] Set / change portal server IP\n"
            "  [bold red]   [2][/] Jail & redirect a user\n"
            "  [bold green][3][/] Release user from jail\n"
            "  [bold cyan]  [4][/] View all jailed users\n"
            "  [bold magenta][5][/] Release ALL jailed users\n"
            "  [dim]         [B][/] Back\n"
        )

        ch = Prompt.ask("[bold cyan]airjail/jail >[/]").upper()

        if ch == "B":
            break

        elif ch == "1":
            REDIRECT_IP   = Prompt.ask("[cyan]Portal server IP[/]")
            REDIRECT_PORT = int(Prompt.ask("[cyan]Port[/]", default="80"))
            console.print(f"[green][✓] Portal set → {REDIRECT_IP}:{REDIRECT_PORT}[/]")

        elif ch == "2":
            if not REDIRECT_IP:
                REDIRECT_IP = Prompt.ask("[yellow]Portal IP not set. Enter now[/]")
            devices = scan_network(silent=True)
            if devices:
                table = Table(box=box.SIMPLE, show_header=False)
                table.add_column(style="dim", width=3)
                table.add_column(style="green")
                table.add_column(style="yellow")
                for i, d in enumerate(devices, 1):
                    table.add_row(str(i), d["ip"], d["mac"])
                console.print(table)
                idx = Prompt.ask("[cyan]Select device # or enter IP manually[/]")
                if idx.isdigit() and 1 <= int(idx) <= len(devices):
                    target_ip  = devices[int(idx)-1]["ip"]
                    target_mac = devices[int(idx)-1]["mac"]
                else:
                    target_ip  = idx
                    target_mac = next(
                        (d["mac"] for d in devices if d["ip"]==target_ip), "unknown")
            else:
                target_ip  = Prompt.ask("[cyan]Target IP[/]")
                target_mac = "unknown"

            reason = Prompt.ask("[cyan]Reason[/]", default="Abuse detected")
            _redirect_on(target_ip, REDIRECT_IP, REDIRECT_PORT)
            JAILED[target_mac.lower()] = {
                "ip": target_ip, "reason": reason,
                "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            }
            console.print(
                f"[green][✓] {target_ip} ({target_mac}) jailed "
                f"→ redirected to {REDIRECT_IP}:{REDIRECT_PORT}[/]")

        elif ch == "3":
            mac = Prompt.ask("[cyan]MAC to release[/]").lower()
            if mac in JAILED:
                ip = JAILED[mac].get("ip","")
                if ip: _redirect_off(ip)
                del JAILED[mac]
                console.print(f"[green][✓] {mac} released.[/]")
            else:
                console.print("[yellow]MAC not in jail.[/]")

        elif ch == "4":
            if not JAILED:
                console.print("[yellow]No jailed users.[/]")
            else:
                table = Table(title="[bold red]Jailed Users[/]",
                              box=box.ROUNDED, border_style="red")
                table.add_column("MAC",    style="yellow")
                table.add_column("IP",     style="green")
                table.add_column("Reason", style="red")
                table.add_column("Time",   style="dim")
                for mac, info in JAILED.items():
                    table.add_row(mac, info.get("ip","—"),
                                  info.get("reason","—"), info.get("time","—"))
                console.print(table)

        elif ch == "5":
            if Confirm.ask("[red]Release ALL jailed users?[/]"):
                for info in JAILED.values():
                    if info.get("ip"): _redirect_off(info["ip"])
                JAILED.clear()
                console.print("[green][✓] All users released.[/]")

        if ch != "B":
            input("\nEnter to continue...")

