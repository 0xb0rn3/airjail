def _dns_cb(pkt):
    if pkt.haslayer(DNS) and pkt.haslayer(DNSQR) and pkt[DNS].qr == 0:
        try:
            src  = pkt.src.lower() if hasattr(pkt, "src") else "unknown"
            dom  = pkt[DNSQR].qname.decode(errors="ignore").rstrip(".")
            if dom and dom not in DNS_LOG[src]:
                DNS_LOG[src].append(dom)
                if len(DNS_LOG[src]) > 300:
                    DNS_LOG[src] = DNS_LOG[src][-300:]
        except Exception:
            pass

def start_dns_monitor():
    if "dns" in _stop_events: return
    ev = threading.Event()
    _stop_events["dns"] = ev
    threading.Thread(
        target=lambda: sniff(iface=IFACE, filter="udp port 53",
                              prn=_dns_cb, store=False,
                              stop_filter=lambda _: ev.is_set()),
        daemon=True
    ).start()

def menu_dns_spy():
    if "dns" not in _stop_events:
        start_dns_monitor()

    while True:
        clear(); banner()
        console.print("[bold cyan]── DNS Activity Monitor ──[/]\n")

        if not DNS_LOG:
            console.print("[yellow]Listening... no queries captured yet. Stay on this screen.[/]")
        else:
            table = Table(box=box.ROUNDED, border_style="cyan", show_lines=True,
                          title="[bold cyan]DNS Queries per Device[/]")
            table.add_column("MAC",          style="yellow")
            table.add_column("Queries",      justify="right", style="dim")
            table.add_column("Latest Domains", style="green")

            for mac, domains in sorted(DNS_LOG.items()):
                recent = "  ".join(domains[-4:])
                table.add_row(mac, str(len(domains)), escape(recent))

            console.print(table)

        console.print("\n[dim]  [R] Refresh   [D] Full history for device   [Q] Back[/dim]")
        ch = Prompt.ask("", default="R").upper()

        if ch == "Q":
            break
        elif ch == "D":
            mac = Prompt.ask("[cyan]MAC address[/]").lower()
            if mac in DNS_LOG:
                console.print(f"\n[bold]All DNS queries for {mac}:[/]")
                for i, d in enumerate(DNS_LOG[mac], 1):
                    console.print(f"  [dim]{i:>3}.[/] {escape(d)}")
            else:
                console.print("[yellow]Not found.[/]")
            input("\nEnter to continue...")

